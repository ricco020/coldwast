---
// Feed d'accueil localisé (fr/es) AVEC pagination — miroir de HomeFeed (EN).
// Source de vérité = data/guides.js (filtré par traduction réelle via hasTx).
// Page 1 affiche aussi les 3 blocks ; les pages 2+ uniquement la liste paginée.
import { guides, categories, guideTitle, guideDek, guideHref, catLabel, guideRead, guideCats } from '../data/guides.js';
import { ui, localized } from '../i18n/ui.js';
import { hasTx } from '../data/i18n-articles.js';
import { ctaAngle } from '../data/cta-angle.js';

interface Props { lang: 'fr' | 'es' | 'de' | 'it' | 'pt'; page?: number; pageSize?: number; }
const { lang, page = 1, pageSize = 12 } = Astro.props as Props;
const t = ui[lang];
const homeCta = ctaAngle(lang, 'default'); // home = angle généraliste (pas Haskell)

const stories = guides.filter((g) => hasTx(g.href, lang));
const totalPages = Math.max(1, Math.ceil(stories.length / pageSize));
const cur = Math.min(Math.max(1, page), totalPages);
const pageStories = stories.slice((cur - 1) * pageSize, cur * pageSize);
const lead = pageStories[0];
const rest = pageStories.slice(1);
const popular = stories.slice(0, 4);
const pageHref = (n) => (n <= 1 ? `/${lang}/` : `/${lang}/page/${n}.html`);

const STARTHERE = {
  fr: {
    h: 'Débuter avec Haskell ? Commencez ici',
    steps: [
      { href: '/e/blog/2026-06-14-what-is-haskell.html', l: 'Qu’est-ce que Haskell ?' },
      { href: '/e/blog/2026-06-14-ghcup-install-haskell.html', l: 'Installer la chaîne d’outils (GHCup)' },
      { href: '/e/blog/2026-06-14-haskell-monads.html', l: 'Comprendre les monades' },
    ],
  },
  es: {
    h: '¿Nuevo en Haskell? Empieza aquí',
    steps: [
      { href: '/e/blog/2026-06-14-what-is-haskell.html', l: '¿Qué es Haskell?' },
      { href: '/e/blog/2026-06-14-ghcup-install-haskell.html', l: 'Instalar el toolchain (GHCup)' },
      { href: '/e/blog/2026-06-14-haskell-monads.html', l: 'Entender las mónadas' },
    ],
  },
  de: {
    h: 'Neu bei Haskell? Hier beginnen',
    steps: [
      { href: '/e/blog/2026-06-14-what-is-haskell.html', l: 'Was ist Haskell?' },
      { href: '/e/blog/2026-06-14-ghcup-install-haskell.html', l: 'Die Toolchain installieren (GHCup)' },
      { href: '/e/blog/2026-06-14-haskell-monads.html', l: 'Monaden verstehen' },
    ],
  },
  it: {
    h: 'Nuovo su Haskell? Inizia qui',
    steps: [
      { href: '/e/blog/2026-06-14-what-is-haskell.html', l: 'Cos\'è Haskell?' },
      { href: '/e/blog/2026-06-14-ghcup-install-haskell.html', l: 'Installare il toolchain (GHCup)' },
      { href: '/e/blog/2026-06-14-haskell-monads.html', l: 'Capire le monadi' },
    ],
  },
  pt: {
    h: 'Novo no Haskell? Comece aqui',
    steps: [
      { href: '/e/blog/2026-06-14-what-is-haskell.html', l: 'O que é Haskell?' },
      { href: '/e/blog/2026-06-14-ghcup-install-haskell.html', l: 'Instalar o toolchain (GHCup)' },
      { href: '/e/blog/2026-06-14-haskell-monads.html', l: 'Compreender as mónadas' },
    ],
  },
}[lang];

const BLOCKS = {
  fr: [
    { c:'b1', k:'Démarrer', h:'Installer la chaîne d’outils', p:'GHC, Cabal, Stack et HLS en une installation propre avec GHCup.', a:'Lire le guide →', find:'ghcup-install' },
    { c:'b2', k:'Build', h:'Comprendre les builds Cabal', p:'Sandboxes, builds v2 façon nix et ce qui a vraiment changé.', a:'Lire le guide →', find:'Cabal-sandbox' },
    { c:'b3', k:'Performance', h:'Des builds Haskell plus rapides', p:'Utilisez tous vos cœurs en sécurité avec -j et les sémaphores de build.', a:'Lire le guide →', find:'GSoC-Final' },
  ],
  es: [
    { c:'b1', k:'Empezar', h:'Instalar el toolchain', p:'GHC, Cabal, Stack y HLS en una instalación limpia con GHCup.', a:'Leer la guía →', find:'ghcup-install' },
    { c:'b2', k:'Build', h:'Entender los builds de Cabal', p:'Sandboxes, builds v2 estilo nix y qué cambió realmente.', a:'Leer la guía →', find:'Cabal-sandbox' },
    { c:'b3', k:'Rendimiento', h:'Builds de Haskell más rápidos', p:'Usa todos tus núcleos de forma segura con -j y los semáforos de build.', a:'Leer la guía →', find:'GSoC-Final' },
  ],
  de: [
    { c:'b1', k:'Loslegen', h:'Die Toolchain installieren', p:'GHC, Cabal, Stack und HLS in einer sauberen Installation mit GHCup.', a:'Leitfaden lesen →', find:'ghcup-install' },
    { c:'b2', k:'Build', h:'Cabal-Builds verstehen', p:'Sandboxes, v2-Builds im nix-Stil und was sich wirklich geändert hat.', a:'Leitfaden lesen →', find:'Cabal-sandbox' },
    { c:'b3', k:'Performance', h:'Schnellere Haskell-Builds', p:'Nutzen Sie alle Ihre Kerne sicher mit -j und Build-Semaphoren.', a:'Leitfaden lesen →', find:'GSoC-Final' },
  ],
  it: [
    { c:'b1', k:'Iniziare', h:'Installare il toolchain', p:'GHC, Cabal, Stack e HLS in un\'installazione pulita con GHCup.', a:'Leggi la guida →', find:'ghcup-install' },
    { c:'b2', k:'Build', h:'Capire i build di Cabal', p:'Sandbox, build v2 in stile nix e cosa è cambiato davvero.', a:'Leggi la guida →', find:'Cabal-sandbox' },
    { c:'b3', k:'Prestazioni', h:'Build di Haskell più veloci', p:'Usa tutti i tuoi core in sicurezza con -j e i semafori di build.', a:'Leggi la guida →', find:'GSoC-Final' },
  ],
  pt: [
    { c:'b1', k:'Começar', h:'Instalar o toolchain', p:'GHC, Cabal, Stack e HLS numa instalação limpa com o GHCup.', a:'Ler o guia →', find:'ghcup-install' },
    { c:'b2', k:'Build', h:'Compreender os builds do Cabal', p:'Sandboxes, builds v2 ao estilo nix e o que mudou realmente.', a:'Ler o guia →', find:'Cabal-sandbox' },
    { c:'b3', k:'Desempenho', h:'Builds de Haskell mais rápidos', p:'Use todos os seus núcleos em segurança com -j e os semáforos de build.', a:'Ler o guia →', find:'GSoC-Final' },
  ],
}[lang];
const blocks = BLOCKS.map((b) => ({ ...b, g: guides.find((x) => x.href.includes(b.find)) }));

const AV = {
  perf:    { color:'#d6453a', svg:'<path d="M5 19a8 8 0 1 1 14 0"/><line x1="12" y1="13" x2="16" y2="9"/>' },
  build:   { color:'#c46a12', svg:'<path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"/><path d="M12 12l8-4.5M12 12v9M12 12L4 7.5"/>' },
  tool:    { color:'#2d7d46', svg:'<circle cx="12" cy="12" r="3.2"/><path d="M12 3v2.5M12 18.5V21M4.2 7l2.1 1.2M17.7 15.8l2.1 1.2M4.2 17l2.1-1.2M17.7 8.2l2.1-1.2"/>' },
  compiler:{ color:'#1d6fe0', svg:'<rect x="6" y="6" width="12" height="12" rx="2"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/>' },
  concept: { color:'#6d4ad6', svg:'<path d="M6 5l5 14M14 5c-2 4-2 6 0 14M5 12h7"/>' },
  editor:  { color:'#0e9e90', svg:'<polyline points="8 8 4 12 8 16"/><polyline points="16 8 20 12 16 16"/><line x1="13" y1="6" x2="11" y2="18"/>' },
  deploy:  { color:'#db2777', svg:'<path d="M12 3c3 1.5 5 5 5 9l-5 4-5-4c0-4 2-7.5 5-9z"/><circle cx="12" cy="10" r="1.6"/>' },
  lambda:  { color:'#e0871a', svg:'<path d="M6 5l5 14M14 5c-2 4-2 6 0 14M5 12h7"/>' },
};
function catAvatar(cats=''){
  const c = cats.toLowerCase();
  if (c.includes('performance')) return AV.perf;
  if (c.includes('build')||c.includes('cabal')) return AV.build;
  if (c.includes('toolchain') || c.includes('tooling')) return AV.tool;
  if (c.includes('compiler')) return AV.compiler;
  if (c.includes('editor')) return AV.editor;
  if (c.includes('deployment')) return AV.deploy;
  if (c.includes('concept')) return AV.concept;
  return AV.lambda;
}
---
<div class="wrap">
  <div class="layout">
    <div class="main">
      {lead && (
        <article class="lead">
          <a href={guideHref(lead, lang)} class="lead-media"><img src={lead.img} alt={lead.imgAlt} width="1200" height="675" loading="eager" /></a>
          <p class="by"><a href={localized('/about.html', lang)}>Coldwast</a> <em>{t.wrote}</em></p>
          <h2><a href={guideHref(lead, lang)} set:html={guideTitle(lead, lang)} /></h2>
          <p class="ex"><span class="date">{lead.date}</span> {t.in_word} {guideCats(lead, lang)} — {guideDek(lead, lang)}</p>
          <a class="more" href={guideHref(lead, lang)}>{t.read_more}</a>
          <div class="metab"><span>📅 {guideRead(lead, lang)}</span><span>↻ {t.updated}</span></div>
        </article>
      )}
      {rest.map((s) => (
        <article class="story">
          <span class="ava cat-ava" style={`background:${catAvatar(s.cats).color}`} aria-hidden="true"><svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={catAvatar(s.cats).svg} /></span>
          <div>
            <p class="by"><a href={localized('/about.html', lang)}>Coldwast</a> <em>{t.wrote}</em></p>
            <h3><a href={guideHref(s, lang)} set:html={guideTitle(s, lang)} /></h3>
            <p class="ex"><span class="date">{s.date}</span> {t.in_word} {guideCats(s, lang)} — {guideDek(s, lang)}</p>
            <a class="more" href={guideHref(s, lang)}>{t.read_more}</a>
            <div class="metab"><span>📅 {guideRead(s, lang)}</span><span>↬ {t.updated}</span></div>
          </div>
        </article>
      ))}
      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination" style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;align-items:center;margin:30px 0 8px;">
          {cur > 1 && (<a href={pageHref(cur - 1)} aria-label="Previous" style="padding:8px 14px;border:1px solid currentColor;border-radius:8px;text-decoration:none;font-weight:700;">&larr;</a>)}
          {Array.from({ length: totalPages }, (_, i) => i + 1).map((n) => (
            n === cur
              ? (<span aria-current="page" style="padding:8px 14px;border-radius:8px;font-weight:800;background:#d6453a;color:#fff;">{n}</span>)
              : (<a href={pageHref(n)} style="padding:8px 14px;border:1px solid currentColor;border-radius:8px;text-decoration:none;font-weight:700;">{n}</a>)
          ))}
          {cur < totalPages && (<a href={pageHref(cur + 1)} aria-label="Next" style="padding:8px 14px;border:1px solid currentColor;border-radius:8px;text-decoration:none;font-weight:700;">&rarr;</a>)}
        </nav>
      )}
    </div>
    <aside class="side">
      <div class="affbox">
        <span class="tag">{t.reco}</span>
        <h3>{homeCta.h}</h3>
        <p>{homeCta.p}</p>
        <a class="go" href="/go/cloud.html" rel="sponsored nofollow noopener" target="_blank">{t.aff_cta}</a>
        <p class="disc">{t.aff_disc}</p>
      </div>
      <div class="sidecard starthere">
        <h4>{STARTHERE.h}</h4>
        <ol class="steps">
          {STARTHERE.steps.map((s, i) => (
            <li><span class="n">{i + 1}</span><a href={localized(s.href, lang)}>{s.l}</a></li>
          ))}
        </ol>
      </div>
      <div class="sidecard">
        <h4>{t.popular}</h4>
        <ul>{popular.map((p) => <li><a href={guideHref(p, lang)} set:html={guideTitle(p, lang)} /></li>)}</ul>
      </div>
      <div class="sidecard">
        <h4>{t.browse_topic}</h4>
        <div class="chiprow">
          {categories.map((c) => <a class="chip" href={localized(`/e/c/${c.slug}.html`, lang)}>{catLabel(c, lang)}</a>)}
        </div>
      </div>
    </aside>
  </div>

  {cur === 1 && (
    <div class="blocks">
      {blocks.map((b) => (
        <div class:list={['block', b.c]}>
          <p class="k">{b.k}</p>
          <h3>{b.h}</h3>
          <p>{b.p}</p>
          <a href={guideHref(b.g, lang)}>{b.a}</a>
        </div>
      ))}
    </div>
  )}
</div>
