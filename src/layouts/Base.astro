---
export interface Props {
  title: string;
  description: string;
  path: string;            // canonical path, e.g. /e/blog/2013-08-20-Cabal-sandbox.html
  image?: string;
  datePublished?: string;
  dateModified?: string;
  type?: string;           // 'article' | 'website'
}
const {
  title,
  description,
  path,
  image = 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=1200&q=80&auto=format&fit=crop',
  datePublished,
  dateModified,
  type = 'website',
} = Astro.props;

const SITE = 'https://coldwa.st';
const canonical = SITE + path;
const year = 2026;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content="coldwa.st" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <meta name="google-site-verification" content="zbK5oTBD3pvfP5FGnXGRdeSEI_DmxGgFYiq4AanaTfQ" />
    <!-- GA4 -->
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-4SQJ15V82L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4SQJ15V82L');
    </script>
    {type === 'article' && datePublished && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'TechArticle',
        headline: title,
        description,
        datePublished,
        dateModified: dateModified || datePublished,
        mainEntityOfPage: canonical,
        publisher: { '@type': 'Organization', name: 'Coldwast', url: SITE },
      })} />
    )}
    <style is:global>
      :root {
        --bg: #12100D; --panel: #1A1712; --edge: #2E2820; --edge2: #3A3225;
        --ink: #EDE6D8; --dim: #B8AE9C; --faint: #8A8270;
        --accent: #E8A33D; --accentd: #B87A28; --amber: #E8A33D; --code: #1C1813;
        --maxw: 860px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0; background: var(--bg); color: var(--ink);
        font-family: 'Source Serif 4', Georgia, 'Times New Roman', serif;
        font-size: 18px; line-height: 1.7; -webkit-font-smoothing: antialiased;
      }
      .mono, code, pre, h1, h2, h3, .kicker, nav, .meta, footer {
        font-family: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;
      }
      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 22px; }
      header.site {
        border-bottom: 1px solid var(--edge); background: rgba(18,16,13,0.85);
        backdrop-filter: blur(6px); position: sticky; top: 0; z-index: 10;
      }
      header.site .wrap { display: flex; align-items: baseline; gap: 26px; padding-top: 16px; padding-bottom: 16px; flex-wrap: wrap; }
      .brand { font-size: 17px; font-weight: 700; color: var(--ink); text-decoration: none; letter-spacing: -0.3px; }
      .brand b { color: var(--accent); } .brand .blink { color: var(--accent); }
      nav { display: flex; gap: 20px; font-size: 14px; }
      nav a { color: var(--dim); text-decoration: none; } nav a:hover { color: var(--accent); }
      main { padding: 40px 0 20px; }
      h1 { font-size: 31px; line-height: 1.25; letter-spacing: -0.5px; margin: 0 0 10px; color: var(--ink); }
      h2 { font-size: 21px; margin: 38px 0 12px; color: var(--accent); }
      h3 { font-size: 17px; margin: 26px 0 8px; color: var(--ink); }
      .kicker { color: var(--accentd); font-size: 13px; text-transform: uppercase; letter-spacing: 1.5px; }
      .meta { color: var(--faint); font-size: 13px; margin: 8px 0 22px; }
      p, li { color: var(--ink); }
      a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--edge2); }
      a:hover { text-decoration-color: var(--accent); }
      hr { border: 0; border-top: 1px solid var(--edge); margin: 34px 0; }
      img.hero { width: 100%; height: auto; border-radius: 8px; border: 1px solid var(--edge); margin: 6px 0 8px; display: block; }
      figcaption { color: var(--faint); font-size: 12px; margin-bottom: 22px; }
      code { background: var(--code); color: #E8D9BC; padding: 2px 6px; border-radius: 4px; font-size: 14.5px; }
      pre { background: var(--code); border: 1px solid var(--edge); border-radius: 8px; padding: 16px 18px; overflow-x: auto; font-size: 14px; line-height: 1.55; }
      pre code { background: none; padding: 0; color: #F0E4CC; }
      blockquote { border-left: 3px solid var(--accentd); margin: 22px 0; padding: 6px 18px; color: var(--dim); background: var(--panel); border-radius: 0 6px 6px 0; }
      .note { background: var(--panel); border: 1px solid var(--edge); border-left: 3px solid var(--amber); border-radius: 0 6px 6px 0; padding: 12px 16px; font-size: 14.5px; color: var(--dim); margin: 22px 0; }
      .postlist { list-style: none; padding: 0; }
      .postlist li { border-bottom: 1px solid var(--edge); padding: 18px 0; }
      .postlist a.t { font-size: 19px; color: var(--ink); text-decoration: none; }
      .postlist a.t:hover { color: var(--accent); }
      .postlist .d { color: var(--faint); font-size: 13px; }
      footer.site { border-top: 1px solid var(--edge); margin-top: 50px; padding: 28px 0 50px; color: var(--faint); font-size: 13px; }
      footer.site a { color: var(--dim); }

      /* ── Professional component system ─────────────────────────── */
      .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--accentd); margin: 0 0 14px; }
      .hero { padding: 18px 0 6px; }
      .hero h1 { font-size: clamp(30px, 5vw, 44px); line-height: 1.12; letter-spacing: -1px; margin: 0 0 18px; }
      .hero h1 .hl { color: var(--accent); }
      .lede { font-size: clamp(17px, 2.2vw, 20px); line-height: 1.6; color: var(--dim); max-width: 60ch; margin: 0 0 26px; }
      .lede strong { color: var(--ink); font-weight: 600; }
      .btnrow { display: flex; flex-wrap: wrap; gap: 14px; align-items: center; margin: 0 0 22px; }
      .btn { font-family: 'JetBrains Mono', monospace; font-size: 14px; text-decoration: none; padding: 11px 20px; border-radius: 7px; transition: all .15s; display: inline-flex; align-items: center; gap: 8px; }
      .btn-primary { background: var(--accent); color: #1A1410; font-weight: 700; border: 1px solid var(--accent); }
      .btn-primary:hover { background: #F2B255; }
      .btn-ghost { color: var(--dim); border: 1px solid var(--edge2); }
      .btn-ghost:hover { color: var(--accent); border-color: var(--accentd); }
      .metarow { display: flex; flex-wrap: wrap; gap: 10px 20px; font-family: 'JetBrains Mono', monospace; font-size: 12.5px; color: var(--faint); list-style: none; padding: 0; margin: 6px 0 0; }
      .metarow li { display: flex; align-items: center; gap: 8px; }
      .metarow li::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--accentd); }
      .chips { display: flex; flex-wrap: wrap; gap: 9px; margin: 0; padding: 0; list-style: none; }
      .chip { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; color: var(--dim); text-decoration: none; padding: 6px 13px; border: 1px solid var(--edge); border-radius: 999px; background: var(--panel); transition: all .15s; }
      .chip:hover { color: var(--accent); border-color: var(--accentd); }
      .sechead { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin: 0 0 18px; }
      .sechead h2 { margin: 0; font-size: 16px; color: var(--ink); }
      .sechead a { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--accent); text-decoration: none; white-space: nowrap; }
      .sechead a:hover { text-decoration: underline; }
      .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .card { display: block; text-decoration: none; background: var(--panel); border: 1px solid var(--edge); border-radius: 10px; padding: 20px 20px 22px; transition: border-color .18s, transform .18s, box-shadow .18s; }
      .card:hover { border-color: var(--accentd); transform: translateY(-3px); box-shadow: 0 10px 30px -16px rgba(232,163,61,0.45); }
      .card.feature { grid-column: 1 / -1; }
      .card .cat { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 1.4px; text-transform: uppercase; color: var(--accentd); }
      .card h3 { font-family: 'Source Serif 4', Georgia, serif; font-size: 20px; line-height: 1.25; color: var(--ink); margin: 10px 0 8px; letter-spacing: -0.2px; }
      .card.feature h3 { font-size: 25px; }
      .card:hover h3 { color: var(--accent); }
      .card p { color: var(--dim); font-size: 14.5px; line-height: 1.55; margin: 0 0 14px; }
      .card .cmeta { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--faint); }
      .cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
      .colitem { border-top: 2px solid var(--accentd); padding-top: 14px; }
      .colitem h4 { font-family: 'JetBrains Mono', monospace; font-size: 13.5px; color: var(--ink); margin: 0 0 7px; letter-spacing: 0.3px; }
      .colitem p { color: var(--dim); font-size: 14px; line-height: 1.55; margin: 0; }
      .block { margin: 56px 0; }
      @media (max-width: 640px) { .cards, .cols { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <a class="brand" href="/">cold<b>wa.st</b><span class="blink">_</span></a>
        <nav>
          <a href="/e/">Guides</a>
          <a href="/e/rss.xml">RSS</a>
          <a href="/about.html">About</a>
        </nav>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site">
      <div class="wrap">
        <p><strong>Coldwast — Programming &amp; Dev Guides.</strong> Independent, community-maintained programming references.</p>
        <p>The Haskell/Cabal guides here are modern, updated rewrites of topics this domain was historically known for. They are <em>not</em> authored by, signed by, or affiliated with the domain's previous owner. All content is original.</p>
        <p>© {year} coldwa.st · <a href="/about.html">About &amp; editorial policy</a> · <a href="/e/rss.xml">RSS</a></p>
      </div>
    </footer>
  </body>
</html>
