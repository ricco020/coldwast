---
export interface Props {
  title: string;
  description: string;
  path: string;
  image?: string;
  datePublished?: string;
  dateModified?: string;
  type?: string;
}
const {
  title,
  description,
  path,
  image = 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=1200&q=80&auto=format&fit=crop',
  datePublished,
  dateModified,
  type = 'website',
} = Astro.props;

const SITE = 'https://coldwa.st';
const canonical = SITE + path;
const year = 2026;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content="coldwa.st" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <meta name="google-site-verification" content="zbK5oTBD3pvfP5FGnXGRdeSEI_DmxGgFYiq4AanaTfQ" />
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-4SQJ15V82L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4SQJ15V82L');
    </script>
    {type === 'article' && datePublished && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'TechArticle',
        headline: title,
        description,
        datePublished,
        dateModified: dateModified || datePublished,
        mainEntityOfPage: canonical,
        publisher: { '@type': 'Organization', name: 'Coldwast', url: SITE },
      })} />
    )}
    <style is:global>
      :root {
        --bg: #1f1f1f; --bg-soft: #1a1a1a; --card: #262626;
        --border: #383838; --border-soft: #2e2e2e;
        --ink: #ececec; --ink-dim: #a6a6a6; --ink-faint: #6f6f6f;
        --accent: #E8A33D; --accent-2: #f2b255;
        --radius: 8px; --maxw: 1200px; --read: 720px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
      body {
        margin: 0; background: var(--bg); color: var(--ink);
        font-family: 'Figtree', ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-size: 17px; line-height: 1.7; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
      }
      code, pre, .mono { font-family: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace; }
      .container { max-width: var(--maxw); margin: 0 auto; padding: 0 28px; }
      .reading { max-width: var(--read); margin: 0 auto; padding: 0 28px; }
      a { color: inherit; }

      /* Header */
      header.site { border-bottom: 1px solid var(--border-soft); background: rgba(31,31,31,.86); backdrop-filter: saturate(160%) blur(8px); position: sticky; top: 0; z-index: 20; }
      header.site .row { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { font-weight: 800; font-size: 18px; letter-spacing: -.4px; color: var(--ink); text-decoration: none; }
      .brand b { color: var(--accent); } .brand .blink { color: var(--accent); }
      header.site nav { display: flex; gap: 28px; }
      header.site nav a { color: var(--ink-dim); text-decoration: none; font-size: 15px; font-weight: 500; transition: color .15s; }
      header.site nav a:hover { color: var(--accent); }

      /* Section heads */
      .sec { margin: 56px 0; }
      .sec-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin: 0 0 26px; }
      .sec-head h2 { font-size: 15px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.4px; color: var(--accent); margin: 0; }
      .sec-head a { color: var(--ink-dim); text-decoration: none; font-size: 14px; font-weight: 600; }
      .sec-head a:hover { color: var(--accent); }

      /* Hero / featured */
      .hero { padding: 64px 0 8px; max-width: 820px; }
      .hero .eyebrow { font-size: 13px; font-weight: 700; letter-spacing: 1.6px; text-transform: uppercase; color: var(--accent); margin: 0 0 16px; }
      .hero h1 { font-size: clamp(34px, 5vw, 52px); line-height: 1.08; letter-spacing: -1.2px; font-weight: 800; margin: 0 0 20px; }
      .hero p.lede { font-size: 19px; line-height: 1.6; color: var(--ink-dim); margin: 0 0 28px; }
      .btnrow { display: flex; flex-wrap: wrap; gap: 12px; }
      .btn { display: inline-flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 600; text-decoration: none; padding: 11px 22px; border-radius: 999px; transition: all .15s; }
      .btn-primary { background: var(--accent); color: #1a1308; border: 1px solid var(--accent); }
      .btn-primary:hover { background: var(--accent-2); }
      .btn-ghost { color: var(--ink); border: 1px solid var(--border); }
      .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

      /* Topic chips */
      .chips { display: flex; flex-wrap: wrap; gap: 9px; padding: 0; margin: 0; list-style: none; }
      .chip { font-size: 14px; font-weight: 500; color: var(--ink-dim); text-decoration: none; padding: 7px 15px; border: 1px solid var(--border); border-radius: 999px; transition: all .15s; }
      .chip:hover { border-color: var(--accent); color: var(--accent); }

      /* Post feed — Ghost/It's FOSS faithful */
      .feed { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
      .pcard { display: flex; flex-direction: column; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; text-decoration: none; color: var(--ink); transition: border-color .18s, transform .18s; }
      .pcard:hover { border-color: #4a4a4a; transform: translateY(-3px); }
      .pcard .media { aspect-ratio: 16 / 9; overflow: hidden; background: var(--bg-soft); }
      .pcard .media img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s; }
      .pcard:hover .media img { transform: scale(1.04); }
      .pcard .body { display: flex; flex-direction: column; flex: 1; padding: 20px 22px 22px; }
      .pcard .tag { font-size: 12px; font-weight: 700; letter-spacing: .6px; text-transform: uppercase; color: var(--accent); margin: 0 0 10px; }
      .pcard h3 { font-size: 21px; line-height: 1.3; font-weight: 700; letter-spacing: -.3px; margin: 0 0 10px; }
      .pcard:hover h3 { color: var(--accent); }
      .pcard .excerpt { font-size: 15px; line-height: 1.6; color: var(--ink-dim); margin: 0; }
      .pcard .foot { display: flex; align-items: center; gap: 10px; margin-top: 18px; padding-top: 16px; border-top: 1px solid var(--border-soft); }
      .pcard.feature { grid-column: 1 / -1; flex-direction: row; }
      .pcard.feature .media { aspect-ratio: auto; flex: 0 0 55%; min-height: 320px; }
      .pcard.feature .body { padding: 34px 38px; justify-content: center; }
      .pcard.feature h3 { font-size: 30px; }
      .pcard.feature .excerpt { font-size: 16px; }
      @media (max-width: 720px) { .pcard.feature { flex-direction: column; } .pcard.feature .media { flex: auto; aspect-ratio: 16/9; min-height: 0; } }

      /* Author meta (avatar monogram) */
      .meta-row { display: flex; align-items: center; gap: 9px; font-size: 13.5px; color: var(--ink-faint); }
      .avatar { width: 26px; height: 26px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: #1a1308; font-weight: 800; font-size: 12px; display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; }
      .meta-row .by { color: var(--ink-dim); font-weight: 600; }
      .meta-row .dot { color: var(--border); }

      /* Value props */
      .cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
      .colitem h4 { font-size: 16px; font-weight: 700; margin: 0 0 8px; }
      .colitem p { font-size: 15px; color: var(--ink-dim); margin: 0; line-height: 1.6; }
      @media (max-width: 720px) { .cols { grid-template-columns: 1fr; } }

      /* ── Article reading ── */
      .crumb { font-size: 14px; color: var(--ink-faint); margin: 30px 0 0; }
      .crumb a { color: var(--ink-dim); text-decoration: none; } .crumb a:hover { color: var(--accent); }
      .crumb span { color: var(--border); margin: 0 8px; }
      .art-h1, .reading h1 { font-size: clamp(30px, 4.4vw, 42px); line-height: 1.14; letter-spacing: -.8px; font-weight: 800; margin: 14px 0 14px; }
      .artmeta { display: flex; flex-wrap: wrap; align-items: center; gap: 9px; font-size: 14px; color: var(--ink-faint); margin: 0 0 26px; }
      .artmeta .by { color: var(--ink-dim); font-weight: 600; } .artmeta .tag { color: var(--accent); } .artmeta .dot { color: var(--border); }
      .kicker { font-size: 13px; font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase; color: var(--accent); margin: 0; }
      .meta { color: var(--ink-faint); font-size: 14px; }
      img.hero { width: 100%; height: auto; border-radius: var(--radius); border: 1px solid var(--border); margin: 8px 0 6px; display: block; }
      figure { margin: 26px 0; } figcaption { color: var(--ink-faint); font-size: 13px; margin-top: 10px; text-align: center; }
      .reading { font-size: 18px; line-height: 1.78; }
      .reading h2 { font-size: 27px; font-weight: 800; letter-spacing: -.4px; margin: 44px 0 14px; }
      .reading h3 { font-size: 21px; font-weight: 700; margin: 30px 0 10px; }
      .reading p, .reading li { color: #d6d6d6; }
      .reading strong { color: var(--ink); }
      .reading a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: rgba(232,163,61,.4); }
      .reading a:hover { text-decoration-color: var(--accent); }
      .reading hr { border: 0; border-top: 1px solid var(--border); margin: 40px 0; }
      code { background: var(--bg-soft); color: var(--accent-2); padding: 2px 7px; border-radius: 5px; font-size: 14.5px; border: 1px solid var(--border-soft); }
      pre { background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 20px; overflow-x: auto; font-size: 14px; line-height: 1.6; }
      pre code { background: none; padding: 0; border: 0; color: #d6d6d6; }
      blockquote { border-left: 3px solid var(--accent); margin: 24px 0; padding: 4px 20px; color: var(--ink-dim); }
      .note { background: var(--card); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 0 var(--radius) var(--radius) 0; padding: 16px 20px; font-size: 15px; color: var(--ink-dim); margin: 26px 0; }
      .codewrap { position: relative; margin: 22px 0; } .codewrap > pre { margin: 0; }
      .copybtn { position: absolute; top: 9px; right: 9px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-faint); background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 4px 10px; cursor: pointer; opacity: 0; transition: all .15s; }
      .codewrap:hover .copybtn { opacity: 1; } .copybtn:hover, .copybtn.ok { color: var(--accent); border-color: var(--accent); }
      .toc { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px 22px; margin: 26px 0; }
      .toc p { font-size: 12px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: var(--ink-faint); margin: 0 0 10px; }
      .toc a { display: block; color: var(--ink-dim); text-decoration: none; font-size: 15px; padding: 4px 0; } .toc a:hover { color: var(--accent); }

      /* Footer */
      footer.site { border-top: 1px solid var(--border-soft); margin-top: 70px; padding: 40px 0 60px; color: var(--ink-faint); font-size: 14px; background: var(--bg-soft); }
      footer.site a { color: var(--ink-dim); text-decoration: none; } footer.site a:hover { color: var(--accent); }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="container row">
        <a class="brand" href="/">cold<b>wa.st</b><span class="blink">_</span></a>
        <nav>
          <a href="/e/">Guides</a>
          <a href="/e/rss.xml">RSS</a>
          <a href="/about.html">About</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <div class="container">
        <p><strong style="color:var(--ink)">Coldwast — Programming &amp; Dev Guides.</strong> Independent, community-maintained programming references.</p>
        <p style="margin-top:6px;max-width:680px">The Haskell/Cabal guides here are modern, updated rewrites of topics this domain was historically known for — original content, not authored by or affiliated with the domain's previous owner.</p>
        <p style="margin-top:14px">© {year} coldwa.st · <a href="/about.html">About &amp; editorial policy</a> · <a href="/e/rss.xml">RSS</a></p>
      </div>
    </footer>
    <script>
      document.querySelectorAll('main pre').forEach((pre) => {
        if (pre.parentElement?.classList.contains('codewrap')) return;
        const wrap = document.createElement('div');
        wrap.className = 'codewrap';
        pre.parentNode.insertBefore(wrap, pre);
        wrap.appendChild(pre);
        const btn = document.createElement('button');
        btn.className = 'copybtn'; btn.type = 'button'; btn.textContent = 'Copy';
        btn.addEventListener('click', async () => {
          try { await navigator.clipboard.writeText(pre.innerText); btn.textContent = 'Copied'; btn.classList.add('ok');
            setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('ok'); }, 1600); } catch {}
        });
        wrap.appendChild(btn);
      });
      const tocEl = document.getElementById('toc');
      if (tocEl) {
        const heads = document.querySelectorAll('main .reading h2');
        if (heads.length >= 3) {
          const label = document.createElement('p'); label.textContent = 'On this page'; tocEl.appendChild(label);
          heads.forEach((h) => {
            if (!h.id) h.id = (h.textContent || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
            const a = document.createElement('a'); a.href = '#' + h.id; a.textContent = h.textContent; tocEl.appendChild(a);
          });
        } else { tocEl.remove(); }
      }
    </script>
  </body>
</html>
