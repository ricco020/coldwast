---
export interface Props {
  title: string; description: string; path: string;
  image?: string; datePublished?: string; dateModified?: string; type?: string;
}
const {
  title, description, path,
  image = 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=1200&q=80&auto=format&fit=crop',
  datePublished, dateModified, type = 'website',
} = Astro.props;
const SITE = 'https://coldwa.st';
const canonical = SITE + path;
const year = 2026;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content="coldwa.st" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <meta name="google-site-verification" content="zbK5oTBD3pvfP5FGnXGRdeSEI_DmxGgFYiq4AanaTfQ" />
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-4SQJ15V82L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date()); gtag('config', 'G-4SQJ15V82L');
    </script>
    {type === 'article' && datePublished && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context':'https://schema.org','@type':'TechArticle',headline:title,description,datePublished,
        dateModified: dateModified || datePublished, mainEntityOfPage: canonical,
        publisher: { '@type':'Organization', name:'Coldwast', url:SITE },
      })} />
    )}
    <style is:global>
      :root {
        --bg:#ffffff; --soft:#f6f7f8; --card:#ffffff; --border:#e6e7ea; --border-soft:#eeeff1;
        --ink:#15171a; --ink-dim:#565b62; --ink-faint:#8b9096;
        --accent:#d98a1f; --accent-ink:#b5710f; --accent-soft:#fbf2e3;
        --g1:#f0a83c; --g2:#c46a12;
        --radius:8px; --maxw:1180px; --read:720px;
      }
      * { box-sizing:border-box; }
      html { scroll-behavior:smooth; -webkit-text-size-adjust:100%; }
      body { margin:0; background:var(--bg); color:var(--ink);
        font-family:'Figtree',ui-sans-serif,system-ui,-apple-system,sans-serif;
        font-size:17px; line-height:1.65; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }
      code,pre,.mono { font-family:'JetBrains Mono',ui-monospace,'SFMono-Regular',Menlo,monospace; }
      a { color:inherit; }
      .container { max-width:var(--maxw); margin:0 auto; padding:0 24px; }
      .reading { max-width:var(--read); margin:0 auto; padding:0 24px; }

      /* Header */
      header.site { background:#fff; border-bottom:1px solid var(--border); position:sticky; top:0; z-index:20; }
      header.site .row { display:flex; align-items:center; justify-content:space-between; height:66px; gap:18px; }
      .brand { font-weight:800; font-size:19px; letter-spacing:-.4px; color:var(--ink); text-decoration:none; }
      .brand b { color:var(--accent); } .brand .blink { color:var(--accent); }
      header.site nav { display:flex; align-items:center; gap:26px; }
      header.site nav a { color:#3c4147; text-decoration:none; font-size:15px; font-weight:600; transition:color .15s; }
      header.site nav a:hover { color:var(--accent); }
      .pill { display:inline-flex; align-items:center; gap:7px; background:var(--accent); color:#fff; font-weight:700; font-size:14px; padding:9px 18px; border-radius:999px; text-decoration:none; border:0; transition:filter .15s; }
      .pill:hover { filter:brightness(1.05); }

      /* Hero — gradient band (It's FOSS / Ghost signature) */
      .hero-band { background:linear-gradient(120deg,var(--g1),var(--g2)); color:#fff; }
      .hero-band .inner { max-width:860px; margin:0 auto; padding:62px 24px 70px; text-align:center; }
      .hero-band .eyebrow { font-size:13px; font-weight:700; letter-spacing:1.8px; text-transform:uppercase; color:rgba(255,255,255,.85); margin:0 0 18px; }
      .hero-band h1 { font-size:clamp(32px,4.6vw,50px); line-height:1.12; letter-spacing:-1px; font-weight:800; margin:0 0 18px; }
      .hero-band p { font-size:19px; line-height:1.55; color:rgba(255,255,255,.92); margin:0 auto 28px; max-width:620px; }
      .hero-band .ctas { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
      .btn-white { background:#fff; color:var(--accent-ink); font-weight:700; font-size:15px; padding:12px 24px; border-radius:999px; text-decoration:none; }
      .btn-white:hover { filter:brightness(.97); }
      .btn-out { background:transparent; color:#fff; border:1.5px solid rgba(255,255,255,.6); font-weight:600; font-size:15px; padding:11px 22px; border-radius:999px; text-decoration:none; }
      .btn-out:hover { border-color:#fff; }

      /* Sections */
      .sec { margin:54px 0; }
      .sec-head { display:flex; align-items:baseline; justify-content:space-between; gap:16px; margin:0 0 24px; border-bottom:1px solid var(--border); padding-bottom:12px; }
      .sec-head h2 { font-size:13px; font-weight:800; text-transform:uppercase; letter-spacing:1.5px; color:var(--ink); margin:0; }
      .sec-head a { color:var(--accent); text-decoration:none; font-size:14px; font-weight:700; }
      .chips { display:flex; flex-wrap:wrap; gap:9px; padding:0; margin:0; list-style:none; }
      .chip { font-size:14px; font-weight:600; color:#3c4147; text-decoration:none; padding:7px 15px; border:1px solid var(--border); border-radius:999px; background:#fff; transition:all .15s; }
      .chip:hover { border-color:var(--accent); color:var(--accent); }

      /* Card feed (It's FOSS: white cards, thumbnail top) */
      .feed { display:grid; grid-template-columns:repeat(auto-fit,minmax(290px,1fr)); gap:28px; }
      .pcard { display:flex; flex-direction:column; background:#fff; border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; text-decoration:none; color:var(--ink); transition:box-shadow .2s, transform .2s; }
      .pcard:hover { box-shadow:0 12px 28px -14px rgba(20,23,26,.22); transform:translateY(-3px); }
      .pcard .media { aspect-ratio:16/9; overflow:hidden; background:var(--soft); }
      .pcard .media img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .4s; }
      .pcard:hover .media img { transform:scale(1.04); }
      .pcard .body { display:flex; flex-direction:column; flex:1; padding:18px 20px 20px; }
      .pcard .tag { align-self:flex-start; font-size:11.5px; font-weight:700; letter-spacing:.4px; text-transform:uppercase; color:var(--accent-ink); background:var(--accent-soft); padding:4px 10px; border-radius:999px; margin:0 0 12px; }
      .pcard h3 { font-size:20px; line-height:1.32; font-weight:700; letter-spacing:-.2px; margin:0 0 9px; color:var(--ink); }
      .pcard:hover h3 { color:var(--accent-ink); }
      .pcard .excerpt { font-size:14.5px; line-height:1.55; color:var(--ink-dim); margin:0; }
      .pcard .foot { display:flex; align-items:center; gap:9px; margin-top:16px; padding-top:14px; border-top:1px solid var(--border-soft); }
      .pcard.feature { grid-column:1/-1; flex-direction:row; }
      .pcard.feature .media { aspect-ratio:auto; flex:0 0 52%; min-height:300px; }
      .pcard.feature .body { padding:30px 34px; justify-content:center; }
      .pcard.feature h3 { font-size:28px; }
      .pcard.feature .excerpt { font-size:15.5px; }
      @media (max-width:680px){ .pcard.feature{flex-direction:column} .pcard.feature .media{flex:auto;aspect-ratio:16/9;min-height:0} }
      .meta-row { display:flex; align-items:center; gap:8px; font-size:13px; color:var(--ink-faint); }
      .avatar { width:26px; height:26px; border-radius:50%; background:linear-gradient(135deg,var(--g1),var(--g2)); color:#fff; font-weight:800; font-size:12px; display:inline-flex; align-items:center; justify-content:center; flex:0 0 auto; }
      .meta-row .by { color:#3c4147; font-weight:700; } .meta-row .dot { color:#c7cace; }

      .cols { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
      .colitem { background:var(--soft); border:1px solid var(--border); border-radius:var(--radius); padding:22px 24px; }
      .colitem h4 { font-size:16px; font-weight:700; margin:0 0 8px; color:var(--ink); }
      .colitem p { font-size:14.5px; color:var(--ink-dim); margin:0; line-height:1.55; }
      @media (max-width:680px){ .cols{grid-template-columns:1fr} .feed{grid-template-columns:1fr} }

      /* Article reading */
      .crumb { font-size:14px; color:var(--ink-faint); margin:26px 0 0; }
      .crumb a { color:var(--ink-dim); text-decoration:none; } .crumb a:hover { color:var(--accent); }
      .crumb span { color:#c7cace; margin:0 8px; }
      .reading h1 { font-size:clamp(30px,4.2vw,42px); line-height:1.16; letter-spacing:-.7px; font-weight:800; margin:14px 0 12px; color:var(--ink); }
      .artmeta { display:flex; flex-wrap:wrap; align-items:center; gap:8px; font-size:14px; color:var(--ink-faint); margin:0 0 24px; }
      .artmeta .by { color:#3c4147; font-weight:700; } .artmeta .tag { color:var(--accent-ink); } .artmeta .dot { color:#c7cace; }
      .kicker { font-size:12.5px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; color:var(--accent-ink); margin:0; }
      .meta { color:var(--ink-faint); font-size:14px; }
      img.hero { width:100%; height:auto; border-radius:var(--radius); border:1px solid var(--border); margin:8px 0 6px; display:block; }
      figure { margin:24px 0; } figcaption { color:var(--ink-faint); font-size:13px; margin-top:9px; text-align:center; }
      .reading { font-size:18px; line-height:1.78; color:#2b2f34; }
      .reading h2 { font-size:26px; font-weight:800; letter-spacing:-.3px; margin:42px 0 12px; color:var(--ink); }
      .reading h3 { font-size:20px; font-weight:700; margin:28px 0 8px; color:var(--ink); }
      .reading strong { color:var(--ink); }
      .reading a { color:var(--accent-ink); text-decoration:underline; text-underline-offset:3px; text-decoration-color:rgba(217,138,31,.4); }
      .reading a:hover { text-decoration-color:var(--accent); }
      .reading hr { border:0; border-top:1px solid var(--border); margin:38px 0; }
      .reading table { width:100%; border-collapse:collapse; font-size:15px; margin:20px 0; }
      .reading th { text-align:left; background:var(--soft); border-bottom:2px solid var(--border); padding:9px 12px; font-weight:700; }
      .reading td { border-bottom:1px solid var(--border-soft); padding:9px 12px; vertical-align:top; }
      code { background:var(--soft); color:#a8560a; padding:2px 6px; border-radius:5px; font-size:14.5px; border:1px solid var(--border); }
      pre { background:#1c2330; color:#e6e7ea; border:1px solid #2a3340; border-radius:var(--radius); padding:18px 20px; overflow-x:auto; font-size:14px; line-height:1.6; }
      pre code { background:none; padding:0; border:0; color:#e6e7ea; }
      blockquote { border-left:3px solid var(--accent); margin:22px 0; padding:4px 20px; color:var(--ink-dim); }
      .note { background:var(--accent-soft); border:1px solid #f0dcb6; border-left:3px solid var(--accent); border-radius:0 var(--radius) var(--radius) 0; padding:15px 18px; font-size:15px; color:#6b4d12; margin:24px 0; }
      .codewrap { position:relative; margin:22px 0; } .codewrap > pre { margin:0; }
      .copybtn { position:absolute; top:9px; right:9px; font-family:'JetBrains Mono',monospace; font-size:11px; color:#b8bcc2; background:#222b38; border:1px solid #344150; border-radius:6px; padding:4px 10px; cursor:pointer; opacity:0; transition:all .15s; }
      .codewrap:hover .copybtn { opacity:1; } .copybtn:hover,.copybtn.ok { color:#fff; border-color:#4a5a6e; }
      .toc { background:var(--soft); border:1px solid var(--border); border-radius:var(--radius); padding:18px 22px; margin:24px 0; }
      .toc p { font-size:12px; font-weight:800; letter-spacing:1px; text-transform:uppercase; color:var(--ink-faint); margin:0 0 10px; }
      .toc a { display:block; color:var(--ink-dim); text-decoration:none; font-size:15px; padding:4px 0; } .toc a:hover { color:var(--accent-ink); }

      footer.site { border-top:1px solid var(--border); margin-top:64px; padding:40px 0 56px; background:var(--soft); color:var(--ink-faint); font-size:14px; }
      footer.site a { color:var(--ink-dim); text-decoration:none; } footer.site a:hover { color:var(--accent); }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="container row">
        <a class="brand" href="/">cold<b>wa.st</b><span class="blink">_</span></a>
        <nav>
          <a href="/e/">Guides</a>
          <a href="/about.html">About</a>
          <a class="pill" href="/e/rss.xml">Follow via RSS</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site">
      <div class="container">
        <p style="color:var(--ink);font-weight:700;font-size:16px;margin:0">Coldwast — Programming &amp; Dev Guides</p>
        <p style="margin:8px 0 0;max-width:640px">Independent, community-maintained programming references. The Haskell/Cabal guides are modern, updated rewrites of topics this domain was historically known for — original content, not authored by or affiliated with the domain's previous owner.</p>
        <p style="margin:16px 0 0">© {year} coldwa.st · <a href="/about.html">About &amp; editorial policy</a> · <a href="/e/rss.xml">RSS</a></p>
      </div>
    </footer>
    <script>
      document.querySelectorAll('main pre').forEach((pre) => {
        if (pre.parentElement?.classList.contains('codewrap')) return;
        const wrap=document.createElement('div'); wrap.className='codewrap';
        pre.parentNode.insertBefore(wrap,pre); wrap.appendChild(pre);
        const btn=document.createElement('button'); btn.className='copybtn'; btn.type='button'; btn.textContent='Copy';
        btn.addEventListener('click', async()=>{ try{ await navigator.clipboard.writeText(pre.innerText); btn.textContent='Copied'; btn.classList.add('ok'); setTimeout(()=>{btn.textContent='Copy';btn.classList.remove('ok');},1600);}catch{} });
        wrap.appendChild(btn);
      });
      const tocEl=document.getElementById('toc');
      if (tocEl){ const heads=document.querySelectorAll('main .reading h2');
        if (heads.length>=3){ const l=document.createElement('p'); l.textContent='On this page'; tocEl.appendChild(l);
          heads.forEach((h)=>{ if(!h.id) h.id=(h.textContent||'').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,''); const a=document.createElement('a'); a.href='#'+h.id; a.textContent=h.textContent; tocEl.appendChild(a); });
        } else { tocEl.remove(); } }
    </script>
  </body>
</html>
