---
export interface Props {
  title: string; description: string; path: string;
  image?: string; datePublished?: string; dateModified?: string; type?: string; lang?: string;
}
const {
  title, description, path,
  image = 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=1200&q=80&auto=format&fit=crop',
  datePublished, dateModified, type = 'website', lang = 'en',
} = Astro.props;
import { guides, categories } from '../data/guides.js';
import { ui, localized, LOCALES } from '../i18n/ui.js';
const t = ui[lang] || ui.en;
const SITE = 'https://coldwa.st';
const canonical = SITE + path;
const year = 2026;
// On article pages, surface related guides + an affiliate CTA for retention.
const isArticle = path.includes('/e/blog/');
// Canonical (locale-stripped) path so the current article is excluded from
// "Keep reading" on FR/ES pages too (g.href is the EN canonical href).
const canonPath = path.replace(/^\/(fr|es)(?=\/|$)/, '');
const related = isArticle ? guides.filter((g) => g.href !== canonPath).slice(0, 4) : [];
// Catbar: "All guides" + each category. SLUGS identical across locales; only
// the LABEL and the locale prefix change.
const cats = [
  { l: t.all_guides, h: '/e/' },
  ...categories.map((c) => ({
    l: (lang === 'fr' && c.label_fr) || (lang === 'es' && c.label_es) || c.label,
    h: `/e/c/${c.slug}.html`,
  })),
];
const cur = path;
// Root-relative path stripped of any /fr or /es prefix → used for the language
// switcher and hreflang alternates.
const rootPath = path.replace(/^\/(fr|es)(?=\/|$)/, '') || '/';
const switcher = LOCALES.map((l) => ({
  code: l, label: l.toUpperCase(), href: localized(rootPath, l), on: l === lang,
}));
const alts = [
  { hl: 'en', href: SITE + localized(rootPath, 'en') },
  { hl: 'fr', href: SITE + localized(rootPath, 'fr') },
  { hl: 'es', href: SITE + localized(rootPath, 'es') },
  { hl: 'x-default', href: SITE + localized(rootPath, 'en') },
];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alts.map((a) => <link rel="alternate" hreflang={a.hl} href={a.href} />)}
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content="coldwa.st" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <meta name="google-site-verification" content="zbK5oTBD3pvfP5FGnXGRdeSEI_DmxGgFYiq4AanaTfQ" />
    <script is:inline>
      // Analytics is loaded only after explicit consent (see cookie banner).
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.loadAnalytics = function(){
        if (window.__ga_loaded) return; window.__ga_loaded = true;
        var s = document.createElement('script'); s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-4SQJ15V82L';
        document.head.appendChild(s);
        gtag('js', new Date()); gtag('config', 'G-4SQJ15V82L', { anonymize_ip: true });
      };
      if (localStorage.getItem('cw-consent') === 'yes') window.loadAnalytics();
    </script>
    {type === 'article' && datePublished && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context':'https://schema.org','@type':'TechArticle',headline:title,description,datePublished,
        dateModified: dateModified || datePublished, mainEntityOfPage: canonical,
        publisher: { '@type':'Organization', name:'Coldwast', url:SITE },
      })} />
    )}
    {!(type === 'article' && datePublished) && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context':'https://schema.org','@type':'WebSite', name:'Coldwast', url:SITE,
        description:'Independent, community-maintained programming guides on Haskell and the modern Haskell developer toolchain.',
        publisher: { '@type':'Organization', name:'Coldwast', url:SITE },
        potentialAction: {
          '@type':'SearchAction',
          target: { '@type':'EntryPoint', urlTemplate: SITE + '/e/search.html?q={search_term_string}' },
          'query-input':'required name=search_term_string',
        },
      })} />
    )}
    <style is:global>
      :root {
        --bar:#e0871a; --bar-d:#c46a12; --brand:#b5710f; --brand-ink:#9a5a08;
        --link:#1d6fe0; --ink:#23252a; --ink-dim:#565b62; --ink-faint:#8b9096;
        --paper:#ffffff; --soft:#f7f5f1; --border:#e7e4dd; --pill:#fbeede; --pill-on:#e0871a;
        --tagbg:#e9f3ec; --tagink:#1f7a45;
        --radius:10px; --maxw:1200px;
      }
      * { box-sizing:border-box; }
      html { scroll-behavior:smooth; -webkit-text-size-adjust:100%; }
      body { margin:0; color:var(--ink);
        background:#faf7f1;
        background-image:radial-gradient(1100px 420px at 50% -120px, #fde7d0 0%, rgba(253,231,208,0) 70%);
        background-repeat:no-repeat;
        font-family:'Source Serif 4',Georgia,'Times New Roman',serif; font-size:18px; line-height:1.65;
        -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }
      h1,h2,h3,h4,.display,.brand,nav.top a,.cat,.btn,.metab { font-family:'Baloo 2',ui-rounded,system-ui,sans-serif; }
      code,pre,.mono { font-family:'JetBrains Mono',ui-monospace,Menlo,monospace; }
      a { color:var(--link); }
      .wrap { max-width:var(--maxw); margin:0 auto; padding:0 22px; }

      /* ── Top bar (Smashing) ── */
      .topbar { background:linear-gradient(180deg,#e89327 0%,var(--bar-d) 100%); color:#fff; box-shadow:0 2px 14px rgba(196,106,18,.22); }
      .topbar .row { display:flex; align-items:center; gap:18px; height:72px; }
      .brand { color:#fff; text-decoration:none; font-weight:800; font-size:22px; letter-spacing:-.3px; display:flex; align-items:center; gap:9px; }
      .brand .logo { width:38px; height:38px; border-radius:9px; background:#fff; color:var(--bar-d); display:flex; align-items:center; justify-content:center; font-size:22px; font-weight:800; }
      nav.top { display:flex; align-items:center; gap:22px; margin-left:8px; }
      nav.top a { color:#fff; text-decoration:none; font-weight:600; font-size:18.5px; opacity:.96; }
      nav.top a:hover { opacity:.78; }
      .langsw { display:flex; align-items:center; gap:2px; margin-left:auto; font-family:'Baloo 2',sans-serif; font-size:14px; font-weight:700; }
      .langsw a { color:#fff; text-decoration:none; opacity:.7; padding:4px 8px; border-radius:7px; }
      .langsw a:hover { opacity:1; }
      .langsw a.on { opacity:1; background:rgba(255,255,255,.22); }
      .langsw + .search { margin-left:14px; }
      .search { margin-left:auto; display:flex; align-items:center; gap:9px; background:#fff; border-radius:999px; padding:9px 18px; color:var(--ink-faint); min-width:230px; font-family:'Baloo 2',sans-serif; font-size:15px; }
      .search input { border:0; outline:0; background:none; font:inherit; color:var(--ink); width:100%; }
      .search input::placeholder { color:var(--ink-faint); }
      .affbox { background:#fff7ee; border:1px solid #f1ddc2; border-radius:14px; padding:22px 22px; }
      .affbox .tag { display:inline-block; background:var(--bar); color:#fff; font-weight:800; font-family:'Baloo 2',sans-serif; font-size:12px; letter-spacing:.5px; text-transform:uppercase; padding:5px 12px; border-radius:999px; margin-bottom:12px; }
      .affbox h3 { font-size:20px; line-height:1.2; margin:0 0 8px; color:var(--ink); font-family:'Baloo 2',sans-serif; }
      .affbox p { font-size:14.5px; color:var(--ink-dim); margin:0 0 14px; }
      .affbox .go { display:inline-block; background:var(--bar); color:#fff; border-radius:9px; padding:10px 18px; font-family:'Baloo 2',sans-serif; font-weight:700; font-size:15px; text-decoration:none; }
      .affbox .go:hover { background:var(--bar-d); }
      .affbox .disc { font-size:12px; color:var(--ink-faint); margin:12px 0 0; }
      .topiclist a { font-family:'Baloo 2',sans-serif; }
      .searchpage { margin:8px 0 4px; }
      .searchpage input { width:100%; max-width:520px; border:2px solid var(--border); border-radius:12px; padding:13px 18px; font-family:'Source Serif 4',serif; font-size:17px; }
      .searchpage input:focus { outline:0; border-color:var(--bar); }
      .cookiebar { position:fixed; left:16px; right:16px; bottom:16px; z-index:90; max-width:760px; margin:0 auto; background:#fff; border:1px solid var(--border); border-radius:14px; box-shadow:0 10px 40px rgba(0,0,0,.16); padding:16px 20px; display:flex; gap:14px; align-items:center; flex-wrap:wrap; font-size:14.5px; color:var(--ink-dim); }
      .cookiebar[hidden] { display:none; }
      .cookiebar p { margin:0; flex:1; min-width:220px; }
      .cookiebar a { color:var(--brand); }
      .cookiebar .btns { display:flex; gap:8px; }
      .cookiebar button { font-family:'Baloo 2',sans-serif; font-weight:700; font-size:14px; border-radius:9px; padding:9px 16px; cursor:pointer; border:1px solid var(--border); background:#fff; color:var(--ink-dim); }
      .cookiebar button.acc { background:var(--bar); color:#fff; border-color:var(--bar); }
      .artcta { max-width:760px; margin:10px auto 0; padding:0 22px; }
      .artcta { display:flex; gap:18px; align-items:center; flex-wrap:wrap; background:#fff7ee; border:1px solid #f1ddc2; border-radius:14px; padding:22px 24px; }
      .artcta .tag { background:var(--bar); color:#fff; font-weight:800; font-family:'Baloo 2',sans-serif; font-size:11px; letter-spacing:.5px; text-transform:uppercase; padding:5px 11px; border-radius:999px; }
      .artcta h3 { margin:0 0 4px; font-size:19px; font-family:'Baloo 2',sans-serif; color:var(--ink); }
      .artcta p { margin:0; font-size:14.5px; color:var(--ink-dim); }
      .artcta > div { flex:1; min-width:240px; }
      .artcta .go { background:var(--bar); color:#fff; border-radius:9px; padding:11px 20px; font-family:'Baloo 2',sans-serif; font-weight:700; text-decoration:none; white-space:nowrap; }
      .artcta .go:hover { background:var(--bar-d); }
      .related { max-width:760px; margin:34px auto 0; padding:0 22px; }
      .related h3 { font-family:'Baloo 2',sans-serif; font-size:22px; color:var(--ink); margin:0 0 14px; }
      .related ul { list-style:none; padding:0; margin:0; display:grid; grid-template-columns:1fr 1fr; gap:10px; }
      .related a { display:flex; justify-content:space-between; gap:12px; align-items:baseline; border:1px solid var(--border); border-radius:11px; padding:14px 16px; text-decoration:none; color:var(--ink); font-family:'Baloo 2',sans-serif; font-weight:600; transition:all .15s; }
      .related a:hover { border-color:var(--bar); background:var(--soft); }
      .related .rm { color:var(--ink-faint); font-size:13px; white-space:nowrap; }
      @media (max-width:700px){ .related ul{grid-template-columns:1fr} }
      /* ── Article 2-column layout (reading left + dynamic right rail) ── */
      .artgrid { max-width:1160px; margin:0 auto; padding:0 22px; display:grid; grid-template-columns:minmax(0,1fr) 308px; gap:54px; align-items:start; }
      .artgrid .artmain .reading { max-width:none; margin:0; padding:0; }
      .artside { margin-top:96px; }
      .artside .sticky { position:sticky; top:88px; display:grid; gap:20px; }
      .artside h4 { font-family:'Baloo 2',sans-serif; font-size:12px; font-weight:800; text-transform:uppercase; letter-spacing:1px; color:var(--ink-faint); margin:0 0 12px; }
      .toc2 { background:var(--soft); border:1px solid var(--border); border-radius:14px; padding:18px 20px; }
      .toc2:empty { display:none; }
      .toc2 .lbl { display:block; font-family:'Baloo 2',sans-serif; font-size:12px; font-weight:800; letter-spacing:1px; text-transform:uppercase; color:var(--ink-faint); margin:0 0 10px; }
      .toc2 a { display:block; color:var(--ink-dim); text-decoration:none; font-size:14.5px; padding:5px 0; border-left:2px solid transparent; padding-left:12px; margin-left:-2px; font-family:'Baloo 2',sans-serif; font-weight:600; transition:all .12s; }
      .toc2 a:hover { color:var(--brand); border-left-color:var(--bar); }
      .affmini { background:linear-gradient(180deg,#fff7ee,#fdeed9); border:1px solid #f1ddc2; border-radius:14px; padding:20px 20px; }
      .affmini .tag { display:inline-block; background:var(--bar); color:#fff; font-weight:800; font-family:'Baloo 2',sans-serif; font-size:11px; letter-spacing:.5px; text-transform:uppercase; padding:5px 11px; border-radius:999px; margin-bottom:10px; }
      .affmini .amh { font-size:17px; color:var(--ink); margin:0 0 7px; font-family:'Baloo 2',sans-serif; text-transform:none; letter-spacing:0; font-weight:700; }
      .affmini p { font-size:13.5px; color:var(--ink-dim); margin:0 0 13px; line-height:1.55; }
      .affmini .go { display:inline-block; background:var(--bar); color:#fff; border-radius:9px; padding:9px 16px; font-family:'Baloo 2',sans-serif; font-weight:700; font-size:14px; text-decoration:none; }
      .affmini .go:hover { background:var(--bar-d); }
      .affmini .disc { font-size:11.5px; color:var(--ink-faint); margin:11px 0 0; }
      .sidebox { background:#fff; border:1px solid var(--border); border-radius:14px; padding:20px 20px; }
      .relmini ul { list-style:none; padding:0; margin:0; }
      .relmini li { border-top:1px solid var(--border); }
      .relmini li:first-child { border-top:0; }
      .relmini a { display:block; padding:9px 0; color:var(--ink); text-decoration:none; font-family:'Baloo 2',sans-serif; font-weight:600; font-size:14.5px; line-height:1.35; transition:color .12s; }
      .relmini a:hover { color:var(--brand); }
      .chiprow { display:flex; flex-wrap:wrap; gap:7px; }
      .chip { font-family:'Baloo 2',sans-serif; font-weight:700; font-size:12.5px; color:var(--brand-ink); background:var(--pill); border:1px solid #f2ddbf; padding:5px 12px; border-radius:999px; text-decoration:none; transition:all .12s; }
      .chip:hover { background:#f7e3c6; }
      @media (max-width:940px){
        .artgrid { grid-template-columns:1fr; gap:30px; }
        .artside { margin-top:0; }
        .artside .sticky { position:static; }
        .toc2 { display:none; }
      }
      @media (max-width:760px){
        .topbar .row { height:auto; min-height:64px; flex-wrap:wrap; gap:6px 18px; padding-top:12px; padding-bottom:12px; }
        .search { display:none; }
        nav.top { margin-left:0; gap:18px; }
        .brand { font-size:20px; }
      }

      /* ── Category pills ── */
      .catbar { border-bottom:1px solid #efe7d8; background:rgba(255,253,249,.85); backdrop-filter:saturate(1.2) blur(4px); }
      .catbar .row { display:flex; gap:10px; max-width:none; padding:13px max(22px, calc((100% - var(--maxw))/2 + 22px)); justify-content:safe center; flex-wrap:nowrap; overflow-x:auto; scrollbar-width:none; -ms-overflow-style:none; -webkit-mask-image:linear-gradient(to right, #000 calc(100% - 64px), transparent 100%); mask-image:linear-gradient(to right, #000 calc(100% - 64px), transparent 100%); }
      .catbar .row::-webkit-scrollbar { display:none; }
      .cat { flex:0 0 auto; white-space:nowrap; font-size:16px; font-weight:700; color:var(--brand-ink); background:var(--pill); padding:8px 18px; border-radius:999px; text-decoration:none; border:1px solid #f2ddbf; transition:transform .12s ease, background .15s, box-shadow .15s; }
      .cat:hover { background:#f7e3c6; transform:translateY(-1px); box-shadow:0 3px 10px rgba(224,135,26,.18); }
      .cat.on { background:var(--pill-on); color:#fff; border-color:var(--bar-d); box-shadow:0 3px 12px rgba(224,135,26,.4); }

      /* ── Layout: content + sidebar ── */
      .layout { display:grid; grid-template-columns:1fr 340px; gap:48px; padding:38px 0 20px; }
      @media (max-width:940px){ .layout { grid-template-columns:1fr; } }

      /* ── Story list item (polaroid author + serif title) ── */
      .story { display:grid; grid-template-columns:96px 1fr; gap:20px; padding:30px 0; border-bottom:1px solid var(--border); }
      .story:first-child { padding-top:6px; }
      .ava { width:84px; height:84px; border-radius:8px; object-fit:cover; transform:rotate(-5deg); box-shadow:5px 6px 0 0 var(--bar); border:3px solid #fff; }
      .ava.mono-ava { display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,var(--bar),var(--bar-d)); color:#fff; font-family:'Baloo 2',sans-serif; font-weight:800; font-size:34px; }
      .ava.cat-ava { display:flex; align-items:center; justify-content:center; }
      .lead { border-bottom:2px solid var(--border); padding-bottom:30px; margin-bottom:10px; }
      .lead .lead-media { display:block; border-radius:16px; overflow:hidden; border:1px solid var(--border); margin-bottom:18px; aspect-ratio:16/9; box-shadow:6px 8px 0 0 var(--pill); }
      .lead .lead-media img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .4s ease; }
      .lead .lead-media:hover img { transform:scale(1.03); }
      .lead h2 { font-size:clamp(28px,3.4vw,40px); line-height:1.08; letter-spacing:-.5px; font-weight:800; margin:6px 0 12px; font-family:'Baloo 2',sans-serif; }
      .lead h2 a { color:var(--ink); text-decoration:none; } .lead h2 a:hover { color:var(--brand); }
      .story:nth-child(2n) .ava { transform:rotate(4deg); }
      .story:nth-child(3n) .ava { transform:rotate(-2.5deg); }
      .story .by { font-family:'Baloo 2',sans-serif; }
      .story .by a { color:var(--brand); font-weight:700; text-decoration:none; } .story .by em { color:var(--ink-faint); font-style:italic; font-family:'Source Serif 4',serif; }
      .story h3 { font-size:28px; line-height:1.18; font-weight:700; letter-spacing:-.3px; margin:6px 0 0; color:var(--ink); }
      .story h3 a { color:inherit; text-decoration:none; } .story h3 a:hover { color:var(--brand); }
      .story h3 code { font-size:.8em; background:var(--pill); color:var(--brand-ink); padding:1px 6px; border-radius:5px; }
      .story .ex { color:var(--ink-dim); font-size:16.5px; margin:12px 0 0; }
      .story .ex .date { color:var(--ink-faint); font-variant:small-caps; letter-spacing:.5px; font-family:'Baloo 2',sans-serif; font-weight:600; }
      .story .more { display:inline-block; margin-top:12px; color:var(--link); font-weight:700; font-family:'Baloo 2',sans-serif; text-decoration:underline; }
      .story .metab { margin-top:14px; display:flex; gap:20px; font-size:13.5px; color:var(--ink-faint); font-weight:600; }
      .story .metab span { display:flex; align-items:center; gap:6px; }

      /* ── Sidebar ── */
      .side > * { margin-bottom:26px; }
      .nlbox { background:#eaf4fd; border-radius:14px; padding:26px 24px; text-align:center; }
      .nlbox .mascot { font-size:54px; line-height:1; }
      .nlbox .tag { display:inline-block; background:#fff; color:var(--bar-d); border:2px solid var(--bar); font-weight:800; font-family:'Baloo 2',sans-serif; padding:7px 16px; border-radius:999px; margin:10px 0 14px; }
      .nlbox h3 { font-size:22px; line-height:1.25; margin:0 0 10px; color:var(--ink); }
      .nlbox p { font-size:15px; color:var(--ink-dim); margin:0 0 16px; }
      .nlbox .field { display:flex; gap:8px; }
      .nlbox input { flex:1; border:1px solid #cfe0f2; border-radius:8px; padding:10px 12px; font-family:'Source Serif 4',serif; font-size:15px; }
      .nlbox .go { background:var(--link); color:#fff; border:0; border-radius:8px; padding:10px 18px; font-family:'Baloo 2',sans-serif; font-weight:700; font-size:15px; cursor:pointer; text-decoration:none; }
      .sidecard { border:1px solid var(--border); border-radius:14px; padding:22px 24px; }
      .sidecard h4 { font-size:13px; text-transform:uppercase; letter-spacing:1.2px; color:var(--ink-faint); margin:0 0 14px; }
      .sidecard ul { list-style:none; padding:0; margin:0; } .sidecard li { padding:8px 0; border-top:1px solid var(--border); }
      .sidecard li:first-child { border-top:0; } .sidecard a { color:var(--ink); text-decoration:none; font-weight:600; font-size:15.5px; font-family:'Baloo 2',sans-serif; } .sidecard a:hover { color:var(--brand); }
      .starthere { background:linear-gradient(180deg,#fffaf3,#fdf2e3); border-color:#f1ddc2; }
      .starthere .steps { list-style:none; padding:0; margin:0; counter-reset:none; }
      .starthere .steps li { display:flex; align-items:center; gap:12px; padding:9px 0; border-top:1px solid #f1e2cd; }
      .starthere .steps li:first-child { border-top:0; }
      .starthere .steps .n { flex:0 0 auto; width:26px; height:26px; border-radius:50%; background:var(--bar); color:#fff; font-family:'Baloo 2',sans-serif; font-weight:800; font-size:14px; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 6px rgba(224,135,26,.35); }
      .starthere .steps a { font-family:'Baloo 2',sans-serif; font-weight:600; font-size:15px; color:var(--ink); text-decoration:none; line-height:1.3; } .starthere .steps a:hover { color:var(--brand); }
      .side .chiprow { display:flex; flex-wrap:wrap; gap:7px; }
      .side .chip { font-family:'Baloo 2',sans-serif; font-weight:700; font-size:13px; color:var(--brand-ink); background:var(--pill); border:1px solid #f2ddbf; padding:6px 13px; border-radius:999px; text-decoration:none; transition:all .12s; }
      .side .chip:hover { background:#f7e3c6; transform:translateY(-1px); }

      /* ── Colored section cards ── */
      .blocks { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin:30px 0 50px; }
      .block { border-radius:16px; padding:26px 26px 28px; }
      .block.b1 { background:#fdf0e0; } .block.b2 { background:#e9f3ec; } .block.b3 { background:#f0ecfb; }
      .block .k { font-size:12px; font-weight:800; text-transform:uppercase; letter-spacing:1px; }
      .block.b1 .k{color:#b5710f} .block.b2 .k{color:#1f7a45} .block.b3 .k{color:#6d28d9}
      .block h3 { font-size:21px; margin:8px 0 8px; color:var(--ink); line-height:1.25; }
      .block p { font-size:15px; color:var(--ink-dim); margin:0 0 12px; }
      .block a { font-family:'Baloo 2',sans-serif; font-weight:700; text-decoration:none; }
      .block.b1 a{color:#b5710f} .block.b2 a{color:#1f7a45} .block.b3 a{color:#6d28d9}
      @media (max-width:760px){ .blocks{grid-template-columns:1fr} }

      /* ── Category page header ── */
      .cathead { padding:34px 0 6px; }
      .cathead .k { font-size:13px; text-transform:uppercase; letter-spacing:1.4px; color:var(--ink-faint); font-family:'Baloo 2',sans-serif; font-weight:700; }
      .cathead h1 { font-size:48px; font-weight:800; margin:6px 0 14px; color:var(--ink); }
      .relrow { display:flex; gap:9px; flex-wrap:wrap; align-items:center; }
      .relrow .lbl { font-style:italic; color:var(--ink-faint); margin-right:4px; }
      .reltag { font-family:'Baloo 2',sans-serif; font-weight:700; font-size:13.5px; color:var(--tagink); background:var(--tagbg); padding:6px 13px; border-radius:999px; text-decoration:none; }
      .count { font-family:'Baloo 2',sans-serif; font-weight:700; color:var(--ink); margin:34px 0 0; border-bottom:2px solid var(--border); padding-bottom:8px; font-size:15px; }
      .count b { color:var(--ink); } .count .lbl { color:var(--ink-faint); text-transform:uppercase; letter-spacing:1px; font-size:13px; }

      /* ── Article reading ── */
      .reading { max-width:760px; margin:0 auto; padding:0 22px; }
      .crumb { font-size:14px; color:var(--ink-faint); margin:26px 0 0; font-family:'Baloo 2',sans-serif; font-weight:600; }
      .crumb a { color:var(--brand); text-decoration:none; } .crumb span { color:#cfccc4; margin:0 8px; }
      .kicker { display:inline-block; font-family:'Baloo 2',sans-serif; font-size:12.5px; font-weight:800; letter-spacing:1px; text-transform:uppercase; color:var(--brand-ink); background:var(--pill); border:1px solid #f2ddbf; padding:5px 13px; border-radius:999px; margin:14px 0 0; }
      .reading h1 { font-size:clamp(34px,4.6vw,46px); line-height:1.12; letter-spacing:-.5px; font-weight:800; margin:12px 0 12px; color:var(--ink); }
      .artmeta { display:flex; flex-wrap:wrap; align-items:center; gap:8px; font-size:14px; color:var(--ink-faint); margin:0 0 24px; font-family:'Baloo 2',sans-serif; font-weight:600; }
      .artmeta .by { color:var(--brand); } .artmeta .tag { color:var(--tagink); } .artmeta .dot { color:#cfccc4; }
      .meta { color:var(--ink-faint); font-size:14px; }
      img.hero { width:100%; height:auto; border-radius:14px; border:1px solid var(--border); margin:8px 0 14px; display:block; box-shadow:8px 10px 0 0 var(--pill); }
      figure { margin:26px 0; } figure img { border-radius:12px; }
      figcaption { color:var(--ink-faint); font-size:13.5px; margin-top:10px; text-align:center; font-family:'Baloo 2',sans-serif; font-style:italic; }
      .reading { font-size:19px; line-height:1.78; color:#2b2f34; }
      .reading h2 { font-size:30px; font-weight:800; letter-spacing:-.3px; margin:46px 0 12px; color:var(--ink); }
      .reading h2::before { content:''; display:block; width:46px; height:4px; background:linear-gradient(90deg,var(--bar),var(--bar-d)); border-radius:3px; margin-bottom:16px; }
      .reading figure + p { font-size:21px; line-height:1.7; color:#33373d; }
      .reading h3 { font-size:23px; font-weight:700; margin:30px 0 8px; color:var(--ink); }
      .reading strong { color:var(--ink); font-weight:600; }
      .reading a { color:var(--link); text-decoration:underline; text-underline-offset:3px; }
      .reading hr { border:0; border-top:1px solid var(--border); margin:38px 0; }
      .reading table { width:100%; border-collapse:collapse; font-size:15.5px; margin:20px 0; }
      .reading th { text-align:left; background:var(--soft); border-bottom:2px solid var(--border); padding:9px 12px; font-weight:700; font-family:'Baloo 2',sans-serif; }
      .reading td { border-bottom:1px solid var(--border); padding:9px 12px; vertical-align:top; }
      code { background:var(--pill); color:var(--brand-ink); padding:2px 7px; border-radius:5px; font-size:15px; }
      pre { background:#23252a; color:#eceff3; border-radius:var(--radius); padding:18px 20px; overflow-x:auto; font-size:14.5px; line-height:1.6; }
      pre code { background:none; padding:0; color:#eceff3; }
      blockquote { border-left:4px solid var(--bar); margin:22px 0; padding:6px 20px; color:var(--ink-dim); background:var(--soft); border-radius:0 8px 8px 0; }
      .note { background:#eaf4fd; border:1px solid #cfe3f8; border-radius:12px; padding:18px 22px; font-size:16px; color:#1a4a78; margin:24px 0; }
      .note strong { color:#0f3a63; }
      .codewrap { position:relative; margin:22px 0; } .codewrap > pre { margin:0; }
      .copybtn { position:absolute; top:9px; right:9px; font-family:'JetBrains Mono',monospace; font-size:11px; color:#aab1ba; background:#181a1e; border:1px solid #34373d; border-radius:6px; padding:4px 10px; cursor:pointer; opacity:0; transition:all .15s; }
      .codewrap:hover .copybtn { opacity:1; } .copybtn:hover,.copybtn.ok { color:#fff; border-color:#4a4e55; }
      .toc { background:var(--soft); border:1px solid var(--border); border-radius:12px; padding:18px 22px; margin:24px 0; }
      .toc:empty { display:none; }
      .toc p { font-family:'Baloo 2',sans-serif; font-size:12px; font-weight:800; letter-spacing:1px; text-transform:uppercase; color:var(--ink-faint); margin:0 0 10px; }
      .toc a { display:block; color:var(--ink-dim); text-decoration:none; font-size:15.5px; padding:4px 0; font-family:'Baloo 2',sans-serif; font-weight:600; } .toc a:hover { color:var(--brand); }

      footer.site { border-top:1px solid var(--border); margin-top:40px; padding:36px 0 56px; background:var(--soft); color:var(--ink-faint); font-size:15px; }
      footer.site a { color:var(--ink-dim); text-decoration:none; } footer.site a:hover { color:var(--brand); }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="wrap row">
        <a class="brand" href={localized('/', lang)}><span class="logo">λ</span>coldwa.st</a>
        <nav class="top">
          <a href={localized('/e/', lang)}>{t.nav_guides}</a>
          <a href={localized('/about.html', lang)}>{t.nav_about}</a>
          <a href="/e/rss.xml">{t.nav_rss}</a>
        </nav>
        <nav class="langsw" aria-label="Language">
          {switcher.map((s) => <a class:list={[s.on && 'on']} href={s.href} hreflang={s.code} aria-current={s.on ? 'true' : undefined}>{s.label}</a>)}
        </nav>
        <form class="search" role="search" action={localized('/e/search.html', lang)} method="get">
          <span aria-hidden="true">🔍</span>
          <input type="search" name="q" placeholder={t.search_ph} aria-label={t.search_ph} />
        </form>
      </div>
    </header>
    <div class="catbar">
      <div class="wrap row">
        {cats.map((c) => <a class:list={['cat', cur === localized(c.h, lang) && 'on']} href={localized(c.h, lang)}>{c.l}</a>)}
      </div>
    </div>
    {isArticle ? (
      <div class="artgrid">
        <main class="artmain"><slot /></main>
        <aside class="artside">
          <div class="sticky">
            <nav class="toc2" id="toc2" aria-label="On this page"></nav>
            <div class="affmini">
              <span class="tag">{t.reco}</span>
              <h4 class="amh">{t.art_aff_h}</h4>
              <p>{t.art_aff_p}</p>
              <a class="go" href="/go/cloud.html" rel="sponsored nofollow noopener" target="_blank">{t.aff_cta}</a>
              <p class="disc">{t.aff_disc}</p>
            </div>
            <div class="sidebox relmini">
              <h4>{t.keep_reading}</h4>
              <ul>
                {related.map((g) => (
                  <li><a href={localized(g.href, lang)}><span class="rt" set:html={(lang==='fr'&&g.title_fr)||(lang==='es'&&g.title_es)||g.title} /></a></li>
                ))}
              </ul>
            </div>
            <div class="sidebox topicmini">
              <h4>{t.browse_topic}</h4>
              <div class="chiprow">
                {categories.map((c) => <a class="chip" href={localized(`/e/c/${c.slug}.html`, lang)}>{(lang==='fr'&&c.label_fr)||(lang==='es'&&c.label_es)||c.label}</a>)}
              </div>
            </div>
          </div>
        </aside>
      </div>
    ) : (
      <main><slot /></main>
    )}
    <footer class="site">
      <div class="wrap">
        <p style="color:var(--ink);font-weight:700;font-size:17px;margin:0;font-family:'Baloo 2',sans-serif">{t.footer_tag}</p>
        <p style="margin:8px 0 0;max-width:640px">{t.footer_about}</p>
        <p style="margin:16px 0 0">© {year} coldwa.st · <a href={localized('/about.html', lang)}>{t.footer_policy}</a> · <a href="/e/rss.xml">{t.nav_rss}</a></p>
      </div>
    </footer>
    <script>
      document.querySelectorAll('main pre').forEach((pre) => {
        if (pre.parentElement?.classList.contains('codewrap')) return;
        const wrap=document.createElement('div'); wrap.className='codewrap';
        pre.parentNode.insertBefore(wrap,pre); wrap.appendChild(pre);
        const btn=document.createElement('button'); btn.className='copybtn'; btn.type='button'; btn.textContent='Copy';
        btn.addEventListener('click', async()=>{ try{ await navigator.clipboard.writeText(pre.innerText); btn.textContent='Copied'; btn.classList.add('ok'); setTimeout(()=>{btn.textContent='Copy';btn.classList.remove('ok');},1600);}catch{} });
        wrap.appendChild(btn);
      });
      const tocEl=document.getElementById('toc2');
      if (tocEl){ const heads=document.querySelectorAll('main .reading h2');
        if (heads.length>=3){ const _lg=document.documentElement.lang||'en'; const _tl=({fr:'Sur cette page',es:'En esta página'})[_lg]||'On this page'; const l=document.createElement('span'); l.className='lbl'; l.textContent=_tl; tocEl.appendChild(l);
          heads.forEach((h)=>{ if(!h.id) h.id=(h.textContent||'').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,''); const a=document.createElement('a'); a.href='#'+h.id; a.textContent=h.textContent; tocEl.appendChild(a); });
        } }
    </script>
    <div class="cookiebar" id="cookiebar" hidden>
      <p>{t.cookie} <a href={localized('/about.html', lang)}>{t.cookie_policy}</a>.</p>
      <div class="btns">
        <button type="button" id="ck-decline">{t.cookie_decline}</button>
        <button type="button" class="acc" id="ck-accept">{t.cookie_accept}</button>
      </div>
    </div>
    <script is:inline>
      (function(){
        var bar = document.getElementById('cookiebar');
        if (!localStorage.getItem('cw-consent')) { bar.hidden = false; }
        document.getElementById('ck-accept').addEventListener('click', function(){
          localStorage.setItem('cw-consent','yes'); bar.hidden = true; if (window.loadAnalytics) window.loadAnalytics();
        });
        document.getElementById('ck-decline').addEventListener('click', function(){
          localStorage.setItem('cw-consent','no'); bar.hidden = true;
        });
      })();
    </script>
  </body>
</html>
