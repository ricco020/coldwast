---
import Base from '../../../layouts/Base.astro';
import GuideFeed from '../../../components/GuideFeed.astro';
import { guides } from '../../../data/guides.js';
import { hasTx } from '../../../data/i18n-articles.js';
const lang = 'fr';
const PAGE_SIZE = 12;
export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const n = guides.filter((g) => hasTx(g.href, 'fr')).length;
  const totalPages = Math.max(1, Math.ceil(n / PAGE_SIZE));
  const paths = [];
  for (let p = 2; p <= totalPages; p++) paths.push({ params: { page: String(p) }, props: { page: p } });
  return paths;
}
const { page } = Astro.props;
---
<Base title={`Coldwast — Guides de programmation & dev (page ${page})`} description="Guides de programmation indépendants, originaux et régulièrement mis à jour. Haskell, Cabal, outils de build et la chaîne d’outils moderne du développeur." path={`/fr/page/${page}.html`} lang={lang}>
  <GuideFeed lang={lang} page={page} pageSize={PAGE_SIZE} />
</Base>
