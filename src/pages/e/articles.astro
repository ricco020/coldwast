---
import Base from '../../layouts/Base.astro';
import { articles } from '../../data/articles.js';
const path = '/e/articles.html';
const title = 'All articles — Coldwast';
const description = 'Browse every Coldwast guide on programming, Haskell, the toolchain and core software concepts.';
---
<Base title={title} description={description} path={path}>
  <main class="wrap" style="max-width:1100px;margin:0 auto;padding:24px 18px;">
    <h1 style="margin:0 0 6px;">All articles</h1>
    <p style="opacity:.75;margin:0 0 24px;">{articles.length} guides on programming, Haskell and core software concepts.</p>
    <div class="archive-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:22px;">
      {articles.map((a) => (
        <article style="border:1px solid rgba(128,128,128,.18);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;">
          {a.img && (
            <a href={a.href} aria-label={a.title}>
              <img src={a.img} alt={a.imgAlt} width="600" height="338" loading="lazy" style="width:100%;height:160px;object-fit:cover;display:block;" />
            </a>
          )}
          <div style="padding:14px 16px;display:flex;flex-direction:column;gap:6px;">
            <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;opacity:.6;">{a.cats}</span>
            <h2 style="font-size:17px;margin:0;line-height:1.3;"><a href={a.href} set:html={a.title} style="text-decoration:none;color:inherit;" /></h2>
            <p style="font-size:13.5px;opacity:.78;margin:0;">{a.dek?.slice(0, 130)}{a.dek && a.dek.length > 130 ? '…' : ''}</p>
            <p style="font-size:12px;opacity:.6;margin:4px 0 0;">{a.date} · {a.read}</p>
          </div>
        </article>
      ))}
    </div>
  </main>
</Base>
