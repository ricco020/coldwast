---
import Base from '../../layouts/Base.astro';
const path = '/e/';
const posts = [
  { url: '/e/blog/2026-06-14-ghcup-install-haskell.html',
    img: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=900&q=72&auto=format&fit=crop',
    tag: 'Haskell · Toolchain', date: 'Jun 14, 2026', read: '8 min',
    title: 'Install Haskell with GHCup: the 2026 Toolchain Guide',
    blurb: 'GHCup is the recommended way to install GHC, Cabal, Stack and HLS in 2026 — clean install, version switching, and the common pitfalls.' },
  { url: '/e/blog/2013-08-20-Cabal-sandbox.html',
    img: 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=900&q=72&auto=format&fit=crop',
    tag: 'Haskell · Build', date: 'Jun 13, 2026', read: '9 min',
    title: 'Cabal Sandboxes: What They Were, and What Replaced Them',
    blurb: 'Per-project dependency isolation from cabal-install 1.18 — and the nix-style v2-build workflow that superseded it.' },
  { url: '/e/blog/2017-09-09-Cabal-2-0.html',
    img: 'https://images.unsplash.com/photo-1517180102446-f3ece451e9d8?w=900&q=72&auto=format&fit=crop',
    tag: 'Haskell · Build', date: 'Jun 13, 2026', read: '7 min',
    title: 'Cabal 2.0: the Release that Reshaped Haskell Builds',
    blurb: 'Nix-style local builds, Backpack mixins, the caret operator and a better solver — and where each stands in 2026.' },
  { url: '/e/blog/2011-08-22-GSoC-Final.html',
    img: 'https://images.unsplash.com/photo-1542831371-29b0f74f9713?w=900&q=72&auto=format&fit=crop',
    tag: 'Haskell · Performance', date: 'Jun 13, 2026', read: '6 min',
    title: 'Parallelising cabal-install: How Haskell Builds Use Your Cores',
    blurb: 'Dependency-graph parallelism, -j builds and GHC job semaphores — the topic a 2011 GSoC project put on the map.' },
];
---
<Base title="Guides — Coldwast Programming &amp; Dev" description="Updated, original programming guides — Haskell, Cabal and the modern dev toolchain. Independent and community-maintained." path={path}>
  <div class="container">
    <section class="hero" style="padding:48px 0 0">
      <p class="eyebrow">All guides</p>
      <h1>Programming &amp; dev guides</h1>
      <p class="lede">Original, regularly-updated references. Currently focused on the Haskell / Cabal toolchain, expanding into general developer tooling.</p>
    </section>
    <section class="sec" style="margin-top:34px">
      <div class="feed">
        {posts.map((p) => (
          <a class="pcard" href={p.url}>
            <div class="media"><img src={p.img} alt="" loading="lazy" width="900" height="506" /></div>
            <div class="body">
              <p class="tag">{p.tag}</p>
              <h3>{p.title}</h3>
              <p class="excerpt">{p.blurb}</p>
              <div class="foot">
                <span class="avatar" aria-hidden="true">C</span>
                <div class="meta-row"><span class="by">Coldwast</span><span class="dot">·</span><span>{p.date}</span><span class="dot">·</span><span>{p.read} read</span></div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>
