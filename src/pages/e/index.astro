---
import Base from '../../layouts/Base.astro';
const path = '/e/';
const stories = [
  { href:'/e/blog/2026-06-14-haskell-list-comprehensions.html', cats:'Haskell, Syntax', title:'Haskell List Comprehensions, Explained (2026)', dek:'A list comprehension builds a list from generators with optional guards — concise and close to set-builder notation. Syntax, multiple generators, guards, and how they relate to map and filter.', date:'Jun 14, 2026', read:'6 min read' },
  { href:'/e/blog/2026-06-14-what-is-haskell.html', cats:'Haskell, Concepts', title:'What Is Haskell? A Clear Introduction (2026)', dek:'Haskell is a purely functional, statically typed, lazy language with powerful type inference. The ideas that define it — purity, immutability, laziness, strong types — what it is used for, and how to start.', date:'Jun 14, 2026', read:'7 min read' },
  { href:'/e/blog/2026-06-14-lazy-evaluation-haskell.html', cats:'Haskell, Concepts', title:'Lazy Evaluation in Haskell, Explained (2026)', dek:'Haskell computes a value only when it is actually needed. What lazy evaluation is, thunks, infinite data structures, the space-leak trap, and forcing strictness with seq and BangPatterns.', date:'Jun 14, 2026', read:'8 min read' },
  { href:'/e/blog/2026-06-14-haskell-monads.html', cats:'Haskell, Concepts', title:'Monads in Haskell, Explained Without the Jargon (2026)', dek:'A monad sequences computations carrying context — Maybe, Either, IO, lists. What it really is, bind (>>=) and return, and do-notation, plainly.', date:'Jun 14, 2026', read:'8 min read' },
  { href:'/e/blog/2026-06-14-ghc-compiler-guide.html', cats:'Haskell, Compiler', title:'GHC, the Glasgow Haskell Compiler: a Practical 2026 Guide', dek:'What GHC is, installing it with GHCup, using GHCi, the flags that matter (-O2, -Wall, -threaded, -j), and how it fits with Cabal and Stack.', date:'Jun 14, 2026', read:'7 min read' },
  { href:'/e/blog/2026-06-14-haskell-language-server.html', cats:'Haskell, Editor', title:'Haskell Language Server (HLS): Setup and Common Fixes (2026)', dek:'What HLS does, installing it with GHCup, wiring it into VS Code and Neovim, matching it to your GHC, and fixing the usual errors.', date:'Jun 14, 2026', read:'7 min read' },
  { href:'/e/blog/2026-06-14-ghcup-install-haskell.html', cats:'Haskell, Toolchain', title:'Install Haskell with GHCup: the 2026 Toolchain Guide', dek:'GHCup is the recommended way to install GHC, Cabal, Stack and HLS in 2026 — clean install, version switching, and the common pitfalls.', date:'Jun 14, 2026', read:'8 min read' },
  { href:'/e/blog/2013-08-20-Cabal-sandbox.html', cats:'Haskell, Build', title:'Cabal Sandboxes: What They Were, and What Replaced Them', dek:'Per-project dependency isolation from cabal-install 1.18 — and the nix-style v2-build workflow that superseded it.', date:'Jun 13, 2026', read:'9 min read' },
  { href:'/e/blog/2017-09-09-Cabal-2-0.html', cats:'Haskell, Build', title:'Cabal 2.0: the Release that Reshaped Haskell Builds', dek:'Nix-style local builds, Backpack mixins, the caret operator and a better solver — and where each stands in 2026.', date:'Jun 13, 2026', read:'7 min read' },
  { href:'/e/blog/2011-08-22-GSoC-Final.html', cats:'Haskell, Performance', title:'Parallelising cabal-install: How Haskell Builds Use Your Cores', dek:'Dependency-graph parallelism, -j builds and GHC job semaphores — the topic a 2011 GSoC project put on the map.', date:'Jun 13, 2026', read:'6 min read' },
];
const related = [
  { l:'Haskell', h:'/e/c/haskell.html' }, { l:'Concepts', h:'/e/c/concepts.html' }, { l:'Cabal & builds', h:'/e/c/cabal.html' },
  { l:'Toolchain', h:'/e/c/toolchain.html' }, { l:'Compiler', h:'/e/c/compiler.html' }, { l:'Performance', h:'/e/c/performance.html' }, { l:'Editor & HLS', h:'/e/c/editor.html' },
];
const AV = {
  perf:    { color:'#d6453a', svg:'<path d="M5 19a8 8 0 1 1 14 0"/><line x1="12" y1="13" x2="16" y2="9"/>' },
  build:   { color:'#c46a12', svg:'<path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"/><path d="M12 12l8-4.5M12 12v9M12 12L4 7.5"/>' },
  tool:    { color:'#2d7d46', svg:'<circle cx="12" cy="12" r="3.2"/><path d="M12 3v2.5M12 18.5V21M4.2 7l2.1 1.2M17.7 15.8l2.1 1.2M4.2 17l2.1-1.2M17.7 8.2l2.1-1.2"/>' },
  compiler:{ color:'#1d6fe0', svg:'<rect x="6" y="6" width="12" height="12" rx="2"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/>' },
  concept: { color:'#6d4ad6', svg:'<path d="M6 5l5 14M14 5c-2 4-2 6 0 14M5 12h7"/>' },
  editor:  { color:'#0e9e90', svg:'<polyline points="8 8 4 12 8 16"/><polyline points="16 8 20 12 16 16"/><line x1="13" y1="6" x2="11" y2="18"/>' },
  deploy:  { color:'#db2777', svg:'<path d="M12 3c3 1.5 5 5 5 9l-5 4-5-4c0-4 2-7.5 5-9z"/><circle cx="12" cy="10" r="1.6"/>' },
  lambda:  { color:'#e0871a', svg:'<path d="M6 5l5 14M14 5c-2 4-2 6 0 14M5 12h7"/>' },
};
function catAvatar(cats=''){
  const c = cats.toLowerCase();
  if (c.includes('performance')) return AV.perf;
  if (c.includes('build')) return AV.build;
  if (c.includes('toolchain') || c.includes('tooling')) return AV.tool;
  if (c.includes('compiler')) return AV.compiler;
  if (c.includes('editor')) return AV.editor;
  if (c.includes('deployment')) return AV.deploy;
  if (c.includes('concept')) return AV.concept;
  return AV.lambda;
}
---
<Base title="Guides — Coldwast Programming &amp; Dev" description="Updated, original programming guides — Haskell, Cabal and the modern dev toolchain. Independent and community-maintained." path={path}>
  <div class="wrap">
    <div class="cathead">
      <p class="k">Category</p>
      <h1>Guides</h1>
      <div class="relrow"><span class="lbl">Also related to</span>
        {related.map((r) => <a class="reltag" href={r.h}>{r.l}</a>)}
      </div>
      <p class="count"><b>{stories.length}</b> <span class="lbl">guides</span></p>
    </div>
    <div class="layout" style="grid-template-columns:1fr">
      <div class="main">
        {stories.map((s) => (
          <article class="story">
            <span class="ava cat-ava" style={`background:${catAvatar(s.cats).color}`} aria-hidden="true"><svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={catAvatar(s.cats).svg} /></span>
            <div>
              <p class="by"><a href="/about.html">Coldwast</a> <em>wrote</em></p>
              <h3><a href={s.href} set:html={s.title} /></h3>
              <p class="ex"><span class="date">{s.date}</span> in {s.cats} — {s.dek}</p>
              <a class="more" href={s.href}>Read more…</a>
              <div class="metab"><span>📅 {s.read}</span><span>↬ Updated 2026</span></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</Base>
