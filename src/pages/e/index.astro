---
import Base from '../../layouts/Base.astro';
const path = '/e/';
const stories = [
  { href:'/e/blog/2026-06-14-haskell-monads.html', cats:'Haskell, Concepts', title:'Monads in Haskell, Explained Without the Jargon (2026)', dek:'A monad sequences computations carrying context — Maybe, Either, IO, lists. What it really is, bind (>>=) and return, and do-notation, plainly.', date:'Jun 14, 2026', read:'8 min read' },
  { href:'/e/blog/2026-06-14-ghc-compiler-guide.html', cats:'Haskell, Compiler', title:'GHC, the Glasgow Haskell Compiler: a Practical 2026 Guide', dek:'What GHC is, installing it with GHCup, using GHCi, the flags that matter (-O2, -Wall, -threaded, -j), and how it fits with Cabal and Stack.', date:'Jun 14, 2026', read:'7 min read' },
  { href:'/e/blog/2026-06-14-haskell-language-server.html', cats:'Haskell, Editor', title:'Haskell Language Server (HLS): Setup and Common Fixes (2026)', dek:'What HLS does, installing it with GHCup, wiring it into VS Code and Neovim, matching it to your GHC, and fixing the usual errors.', date:'Jun 14, 2026', read:'7 min read' },
  { href:'/e/blog/2026-06-14-ghcup-install-haskell.html', cats:'Haskell, Toolchain', title:'Install Haskell with GHCup: the 2026 Toolchain Guide', dek:'GHCup is the recommended way to install GHC, Cabal, Stack and HLS in 2026 — clean install, version switching, and the common pitfalls.', date:'Jun 14, 2026', read:'8 min read' },
  { href:'/e/blog/2013-08-20-Cabal-sandbox.html', cats:'Haskell, Build', title:'Cabal Sandboxes: What They Were, and What Replaced Them', dek:'Per-project dependency isolation from cabal-install 1.18 — and the nix-style v2-build workflow that superseded it.', date:'Jun 13, 2026', read:'9 min read' },
  { href:'/e/blog/2017-09-09-Cabal-2-0.html', cats:'Haskell, Build', title:'Cabal 2.0: the Release that Reshaped Haskell Builds', dek:'Nix-style local builds, Backpack mixins, the caret operator and a better solver — and where each stands in 2026.', date:'Jun 13, 2026', read:'7 min read' },
  { href:'/e/blog/2011-08-22-GSoC-Final.html', cats:'Haskell, Performance', title:'Parallelising cabal-install: How Haskell Builds Use Your Cores', dek:'Dependency-graph parallelism, -j builds and GHC job semaphores — the topic a 2011 GSoC project put on the map.', date:'Jun 13, 2026', read:'6 min read' },
];
const related = ['Haskell','Cabal','GHCup','Build tooling','Performance','Deployment','HLS'];
---
<Base title="Guides — Coldwast Programming &amp; Dev" description="Updated, original programming guides — Haskell, Cabal and the modern dev toolchain. Independent and community-maintained." path={path}>
  <div class="wrap">
    <div class="cathead">
      <p class="k">Category</p>
      <h1>Guides</h1>
      <div class="relrow"><span class="lbl">Also related to</span>
        {related.map((r) => <a class="reltag" href="/e/">{r}</a>)}
      </div>
      <p class="count"><b>{stories.length}</b> <span class="lbl">guides</span></p>
    </div>
    <div class="layout" style="grid-template-columns:1fr">
      <div class="main">
        {stories.map((s) => (
          <article class="story">
            <span class="ava mono-ava" aria-hidden="true">C</span>
            <div>
              <p class="by"><a href="/about.html">Coldwast</a> <em>wrote</em></p>
              <h3><a href={s.href} set:html={s.title} /></h3>
              <p class="ex"><span class="date">{s.date}</span> in {s.cats} — {s.dek}</p>
              <a class="more" href={s.href}>Read more…</a>
              <div class="metab"><span>📅 {s.read}</span><span>↬ Updated 2026</span></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</Base>
