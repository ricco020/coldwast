---
import Base from '../../../layouts/Base.astro';
import GuideFeed from '../../../components/GuideFeed.astro';
import { guides } from '../../../data/guides.js';
import { hasTx } from '../../../data/i18n-articles.js';
const lang = 'de';
const PAGE_SIZE = 12;
export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const n = guides.filter((g) => hasTx(g.href, 'de')).length;
  const totalPages = Math.max(1, Math.ceil(n / PAGE_SIZE));
  const paths = [];
  for (let p = 2; p <= totalPages; p++) paths.push({ params: { page: String(p) }, props: { page: p } });
  return paths;
}
const { page } = Astro.props;
---
<Base title={`Coldwast - Programmier- & Entwickler-Guides (Seite ${page})`} description="Unabhängige, originale und regelmäßig aktualisierte Programmier-Guides. Haskell, Cabal, Build-Werkzeuge und der moderne Werkzeugkasten für Entwickler." path={`/de/page/${page}.html`} lang={lang}>
  <GuideFeed lang={lang} page={page} pageSize={PAGE_SIZE} />
</Base>
