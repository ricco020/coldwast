  <figure>
    <img class="hero" src="https://images.pexels.com/photos/18631424/pexels-photo-18631424.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Ein automatisiertes Förderband transportiert Artikel durch eine Fabrik" width="1200" height="420" loading="eager" />
