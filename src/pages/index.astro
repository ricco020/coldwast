---
import Base from '../layouts/Base.astro';
const stories = [
  { href:'/e/blog/2013-08-20-Cabal-sandbox.html', cats:'Haskell, Cabal, Build tooling', title:'Cabal Sandboxes: What They Were, and What Replaced Them', dek:'The per-project isolation idea that won so completely it became invisible. What sandboxes were, and the nix-style cabal build workflow that superseded them.', date:'Jun 13, 2026', read:'9 min read', img:'https://images.unsplash.com/photo-1629654297299-c8506221ca97?w=1200&q=80&auto=format&fit=crop', imgAlt:'A Linux terminal prompt' },
  { href:'/e/blog/2026-06-14-ghcup-install-haskell.html', cats:'Haskell, Toolchain', title:'Install Haskell with GHCup: the 2026 Toolchain Guide', dek:'GHCup is the recommended way to install GHC, Cabal, Stack and HLS in 2026 — clean install, version switching, and the common pitfalls that trip newcomers.', date:'Jun 14, 2026', read:'8 min read' },
  { href:'/e/blog/2017-09-09-Cabal-2-0.html', cats:'Haskell, Build tooling', title:'Cabal 2.0: the Release that Reshaped Haskell Builds', dek:'Nix-style builds, Backpack, the caret operator and a better solver — what 2.0 introduced and where each feature stands in the 2026 toolchain.', date:'Jun 13, 2026', read:'7 min read' },
  { href:'/e/blog/2011-08-22-GSoC-Final.html', cats:'Haskell, Performance', title:'Parallelising cabal-install: How Haskell Builds Use Your Cores', dek:'Why a build is a dependency graph, how -j builds use your cores, and the modern job-semaphore fix for oversubscription on wide dependency trees.', date:'Jun 13, 2026', read:'6 min read' },
];
const popular = stories.slice(0, 4);
const blocks = [
  { c:'b1', k:'Get started', h:'Install the toolchain', p:'GHC, Cabal, Stack and HLS in one clean setup with GHCup.', a:'Read the guide →', href:'/e/blog/2026-06-14-ghcup-install-haskell.html' },
  { c:'b2', k:'Build', h:'Understand cabal builds', p:'Sandboxes, nix-style v2-builds and what actually changed.', a:'Read the guide →', href:'/e/blog/2013-08-20-Cabal-sandbox.html' },
  { c:'b3', k:'Performance', h:'Faster Haskell builds', p:'Use every core safely with -j and build semaphores.', a:'Read the guide →', href:'/e/blog/2011-08-22-GSoC-Final.html' },
];
const AV = {
  perf:    { color:'#d6453a', svg:'<path d="M5 19a8 8 0 1 1 14 0"/><line x1="12" y1="13" x2="16" y2="9"/>' },
  build:   { color:'#c46a12', svg:'<path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"/><path d="M12 12l8-4.5M12 12v9M12 12L4 7.5"/>' },
  tool:    { color:'#2d7d46', svg:'<circle cx="12" cy="12" r="3.2"/><path d="M12 3v2.5M12 18.5V21M4.2 7l2.1 1.2M17.7 15.8l2.1 1.2M4.2 17l2.1-1.2M17.7 8.2l2.1-1.2"/>' },
  compiler:{ color:'#1d6fe0', svg:'<rect x="6" y="6" width="12" height="12" rx="2"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/>' },
  concept: { color:'#6d4ad6', svg:'<path d="M6 5l5 14M14 5c-2 4-2 6 0 14M5 12h7"/>' },
  editor:  { color:'#0e9e90', svg:'<polyline points="8 8 4 12 8 16"/><polyline points="16 8 20 12 16 16"/><line x1="13" y1="6" x2="11" y2="18"/>' },
  deploy:  { color:'#db2777', svg:'<path d="M12 3c3 1.5 5 5 5 9l-5 4-5-4c0-4 2-7.5 5-9z"/><circle cx="12" cy="10" r="1.6"/>' },
  lambda:  { color:'#e0871a', svg:'<path d="M6 5l5 14M14 5c-2 4-2 6 0 14M5 12h7"/>' },
};
function catAvatar(cats=''){
  const c = cats.toLowerCase();
  if (c.includes('performance')) return AV.perf;
  if (c.includes('build')) return AV.build;
  if (c.includes('toolchain') || c.includes('tooling')) return AV.tool;
  if (c.includes('compiler')) return AV.compiler;
  if (c.includes('editor')) return AV.editor;
  if (c.includes('deployment')) return AV.deploy;
  if (c.includes('concept')) return AV.concept;
  return AV.lambda;
}
---
<Base title="Coldwast — Programming &amp; Dev Guides" description="Independent, original and regularly-updated programming guides. Haskell, Cabal, build tooling and the modern developer toolchain." path="/">
  <div class="wrap">
    <div class="layout">
      <div class="main">
        {stories[0] && (
          <article class="lead">
            <a href={stories[0].href} class="lead-media"><img src={stories[0].img} alt={stories[0].imgAlt} width="1200" height="675" loading="eager" /></a>
            <p class="by"><a href="/about.html">Coldwast</a> <em>wrote</em></p>
            <h2><a href={stories[0].href} set:html={stories[0].title} /></h2>
            <p class="ex"><span class="date">{stories[0].date}</span> in {stories[0].cats} — {stories[0].dek}</p>
            <a class="more" href={stories[0].href}>Read more…</a>
            <div class="metab"><span>📅 {stories[0].read}</span><span>↻ Updated 2026</span></div>
          </article>
        )}
        {stories.slice(1).map((s) => (
          <article class="story">
            <span class="ava cat-ava" style={`background:${catAvatar(s.cats).color}`} aria-hidden="true"><svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={catAvatar(s.cats).svg} /></span>
            <div>
              <p class="by"><a href="/about.html">Coldwast</a> <em>wrote</em></p>
              <h3><a href={s.href} set:html={s.title} /></h3>
              <p class="ex"><span class="date">{s.date}</span> in {s.cats} — {s.dek}</p>
              <a class="more" href={s.href}>Read more…</a>
              <div class="metab"><span>📅 {s.read}</span><span>↬ Updated 2026</span></div>
            </div>
          </article>
        ))}
      </div>
      <aside class="side">
        <div class="affbox">
          <span class="tag">Recommended</span>
          <h3>Deploy your Haskell project</h3>
          <p>You need a real Linux box to build GHC and run your app. Hetzner Cloud gives developers fast NVMe servers from a few euros a month.</p>
          <a class="go" href="/go/cloud.html" rel="sponsored nofollow noopener" target="_blank">Get cloud credit →</a>
          <p class="disc">Affiliate link — supports these free guides.</p>
        </div>
        <div class="sidecard">
          <h4>Popular guides</h4>
          <ul>{popular.map((p) => <li><a href={p.href} set:html={p.title} /></li>)}</ul>
        </div>
        <div class="sidecard">
          <h4>Browse by topic</h4>
          <ul class="topiclist">
            <li><a href="/e/c/haskell.html">Haskell</a></li>
            <li><a href="/e/c/cabal.html">Cabal &amp; builds</a></li>
            <li><a href="/e/c/toolchain.html">Toolchain</a></li>
            <li><a href="/e/c/performance.html">Performance</a></li>
          </ul>
        </div>
      </aside>
    </div>

    <div class="blocks">
      {blocks.map((b) => (
        <div class:list={['block', b.c]}>
          <p class="k">{b.k}</p>
          <h3>{b.h}</h3>
          <p>{b.p}</p>
          <a href={b.href}>{b.a}</a>
        </div>
      ))}
    </div>
  </div>
</Base>
