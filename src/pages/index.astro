---
import Base from '../layouts/Base.astro';
const stories = [
  { href:'/e/blog/2013-08-20-Cabal-sandbox.html', cats:'Haskell, Cabal, Build tooling', title:'Cabal Sandboxes: What They Were, and What Replaced Them', dek:'The per-project isolation idea that won so completely it became invisible. What sandboxes were, and the nix-style cabal build workflow that superseded them.', date:'Jun 13, 2026', read:'9 min read' },
  { href:'/e/blog/2026-06-14-ghcup-install-haskell.html', cats:'Haskell, Toolchain', title:'Install Haskell with GHCup: the 2026 Toolchain Guide', dek:'GHCup is the recommended way to install GHC, Cabal, Stack and HLS in 2026 — clean install, version switching, and the common pitfalls that trip newcomers.', date:'Jun 14, 2026', read:'8 min read' },
  { href:'/e/blog/2017-09-09-Cabal-2-0.html', cats:'Haskell, Build tooling', title:'Cabal 2.0: the Release that Reshaped Haskell Builds', dek:'Nix-style builds, Backpack, the caret operator and a better solver — what 2.0 introduced and where each feature stands in the 2026 toolchain.', date:'Jun 13, 2026', read:'7 min read' },
  { href:'/e/blog/2011-08-22-GSoC-Final.html', cats:'Haskell, Performance', title:'Parallelising cabal-install: How Haskell Builds Use Your Cores', dek:'Why a build is a dependency graph, how -j builds use your cores, and the modern job-semaphore fix for oversubscription on wide dependency trees.', date:'Jun 13, 2026', read:'6 min read' },
];
const popular = stories.slice(0, 4);
const blocks = [
  { c:'b1', k:'Get started', h:'Install the toolchain', p:'GHC, Cabal, Stack and HLS in one clean setup with GHCup.', a:'Read the guide →', href:'/e/blog/2026-06-14-ghcup-install-haskell.html' },
  { c:'b2', k:'Build', h:'Understand cabal builds', p:'Sandboxes, nix-style v2-builds and what actually changed.', a:'Read the guide →', href:'/e/blog/2013-08-20-Cabal-sandbox.html' },
  { c:'b3', k:'Performance', h:'Faster Haskell builds', p:'Use every core safely with -j and build semaphores.', a:'Read the guide →', href:'/e/blog/2011-08-22-GSoC-Final.html' },
];
---
<Base title="Coldwast — Programming &amp; Dev Guides" description="Independent, original and regularly-updated programming guides. Haskell, Cabal, build tooling and the modern developer toolchain." path="/">
  <div class="wrap">
    <div class="layout">
      <div class="main">
        {stories.map((s) => (
          <article class="story">
            <span class="ava mono-ava" aria-hidden="true">C</span>
            <div>
              <p class="by"><a href="/about.html">Coldwast</a> <em>wrote</em></p>
              <h3><a href={s.href} set:html={s.title} /></h3>
              <p class="ex"><span class="date">{s.date}</span> in {s.cats} — {s.dek}</p>
              <a class="more" href={s.href}>Read more…</a>
              <div class="metab"><span>📅 {s.read}</span><span>↬ Updated 2026</span></div>
            </div>
          </article>
        ))}
      </div>
      <aside class="side">
        <div class="nlbox">
          <div class="mascot">λ</div>
          <span class="tag">Dev guides feed</span>
          <h3>New Haskell &amp; dev guides, once they land.</h3>
          <p>Original, regularly-updated references. No spam, no account.</p>
          <div class="field"><input type="email" placeholder="Your email" aria-label="Email" /><a class="go" href="/e/rss.xml">Follow</a></div>
        </div>
        <div class="sidecard">
          <h4>Popular guides</h4>
          <ul>{popular.map((p) => <li><a href={p.href} set:html={p.title} /></li>)}</ul>
        </div>
      </aside>
    </div>

    <div class="blocks">
      {blocks.map((b) => (
        <div class:list={['block', b.c]}>
          <p class="k">{b.k}</p>
          <h3>{b.h}</h3>
          <p>{b.p}</p>
          <a href={b.href}>{b.a}</a>
        </div>
      ))}
    </div>
  </div>
</Base>
