---
import Base from '../layouts/Base.astro';

const guides = [
  {
    href: '/e/blog/2013-08-20-Cabal-sandbox.html',
    img: 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=1100&q=72&auto=format&fit=crop',
    alt: 'Source code on a dark editor screen',
    tag: 'Haskell · Build',
    title: 'Cabal Sandboxes — and what replaced them',
    dek: 'The per-project isolation idea that won so completely it became invisible. What sandboxes were, and the nix-style cabal build workflow that superseded them.',
    date: 'Jun 13, 2026', read: '9 min',
    feature: true,
  },
  {
    href: '/e/blog/2017-09-09-Cabal-2-0.html',
    img: 'https://images.unsplash.com/photo-1517180102446-f3ece451e9d8?w=800&q=72&auto=format&fit=crop',
    alt: 'Laptop showing code in a terminal',
    tag: 'Haskell · Build',
    title: 'Cabal 2.0 — the release that reshaped Haskell builds',
    dek: 'Nix-style builds, Backpack, the caret operator — what 2.0 introduced and where each feature stands today.',
    date: 'Jun 13, 2026', read: '7 min',
  },
  {
    href: '/e/blog/2011-08-22-GSoC-Final.html',
    img: 'https://images.unsplash.com/photo-1542831371-29b0f74f9713?w=800&q=72&auto=format&fit=crop',
    alt: 'Close-up of colourful source code',
    tag: 'Haskell · Performance',
    title: 'Parallelising cabal-install',
    dek: 'Why a build is a dependency graph, how -j builds use your cores, and the modern job-semaphore fix for oversubscription.',
    date: 'Jun 13, 2026', read: '6 min',
  },
];

const stacks = ['Haskell', 'Cabal', 'Build tooling', 'Deployment', 'Performance'];
const principles = [
  { h: 'Original & honest', p: 'Every guide is written from scratch and states what it does not cover. No reposted docs, no marketing.' },
  { h: 'Revised as toolchains move', p: 'Build tools change fast. Guides carry an explicit "updated" date and are rewritten, not left to rot.' },
  { h: 'What real projects ship', p: 'Workflows tested against actual project setups — the commands and trade-offs you hit in practice.' },
];
---
<Base title="Coldwast — Programming &amp; Dev Guides" description="Independent, original and regularly-updated programming guides. Haskell, Cabal, build tooling and the modern developer toolchain." path="/">
  <div class="container">
    <section class="hero">
      <p class="eyebrow">Programming · Dev guides</p>
      <h1>Build guides that stay current.</h1>
      <p class="lede">Original, technically honest programming references — revised as toolchains move. Rooted in the Haskell / Cabal build toolchain, expanding into the wider developer stack: build performance, deployment, and the tools real projects ship on.</p>
      <div class="btnrow">
        <a class="btn btn-primary" href="/e/">Browse all guides <span aria-hidden="true">→</span></a>
        <a class="btn btn-ghost" href="/about.html">Editorial policy</a>
      </div>
    </section>

    <nav class="sec" aria-label="Topics" style="margin-top:40px">
      <ul class="chips">
        {stacks.map((s) => <li><a class="chip" href="/e/">{s}</a></li>)}
      </ul>
    </nav>

    <section class="sec">
      <div class="sec-head">
        <h2>Featured guides</h2>
        <a href="/e/">All guides →</a>
      </div>
      <div class="feed">
        {guides.map((g) => (
          <a class:list={['pcard', g.feature && 'feature']} href={g.href}>
            <div class="media"><img src={g.img} alt={g.alt} loading="lazy" width="1100" height="620" /></div>
            <div class="body">
              <p class="tag">{g.tag}</p>
              <h3>{g.title}</h3>
              <p class="excerpt">{g.dek}</p>
              <div class="foot">
                <span class="avatar" aria-hidden="true">C</span>
                <div class="meta-row"><span class="by">Coldwast</span><span class="dot">·</span><span>{g.date}</span><span class="dot">·</span><span>{g.read} read</span></div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="sec">
      <div class="sec-head"><h2>How these guides are written</h2></div>
      <div class="cols">
        {principles.map((c) => (
          <div class="colitem">
            <h4>{c.h}</h4>
            <p>{c.p}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</Base>
