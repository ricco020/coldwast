  <figure>
    <img class="hero" src="https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?w=1200&q=80&auto=format&fit=crop" alt="Fluxos de código verde num ecrã escuro" width="1200" height="420" loading="eager" />
