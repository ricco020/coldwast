---
import Base from '../../../layouts/Base.astro';
import GuideFeed from '../../../components/GuideFeed.astro';
import { guides } from '../../../data/guides.js';
import { hasTx } from '../../../data/i18n-articles.js';
const lang = 'pt';
const PAGE_SIZE = 12;
export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const n = guides.filter((g) => hasTx(g.href, 'pt')).length;
  const totalPages = Math.max(1, Math.ceil(n / PAGE_SIZE));
  const paths = [];
  for (let p = 2; p <= totalPages; p++) paths.push({ params: { page: String(p) }, props: { page: p } });
  return paths;
}
const { page } = Astro.props;
---
<Base title={`Coldwast — Guias de programação & desenvolvimento (página ${page})`} description="Guias de programação independentes, originais e atualizados regularmente. Haskell, Cabal, ferramentas de build e o moderno conjunto de ferramentas do desenvolvedor." path={`/pt/page/${page}.html`} lang={lang}>
  <GuideFeed lang={lang} page={page} pageSize={PAGE_SIZE} />
</Base>
