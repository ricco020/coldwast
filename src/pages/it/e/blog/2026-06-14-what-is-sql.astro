  <figure>
    <img class="hero" src="https://images.unsplash.com/photo-1487058792275-0ad4aaf24ca7?w=1200&q=80&auto=format&fit=crop" alt="Codice sorgente colorato su un monitor" width="1200" height="420" loading="eager" />
